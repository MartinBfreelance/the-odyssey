        </div>
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-neutral-900/10 to-transparent pointer-events-none"></div>
    </div>

    <!-- TEXTES DE DESCRIPTION CHALEUREUX -->
    <div class="space-y-4 px-2">
      <h2 class="text-xl font-mono uppercase tracking-[0.2em] text-neutral-900 font-bold">MARTIN — THE ODYSSEY</h2>
      <p class="text-xs font-serif italic text-neutral-400">Créateur de Contenu & Récits au long cours</p>
      
      <p class="text-xs text-neutral-500 font-light leading-relaxed max-w-md mx-auto">

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="THE ODYSSEY | Slow Travel Magazine & Guides Complets">
  
  <!-- HERO SLIDER AUTOMATIQUE 3 SECONDES -->
  <section class="relative h-[80vh] w-full bg-neutral-950 flex items-center justify-center text-center px-6 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <!-- Image 1 -->
      <img 
        src="/images/drone/drone-albania-5.JPG" 
        alt="The Odyssey Slide 1" 
        class="slide-img absolute inset-0 w-full h-full object-cover opacity-65 transition-opacity duration-1000 ease-in-out" 
      />
      <!-- Image 2 -->
      <img 
        src="/images/drone/drone-albania-1.JPG" 
        alt="The Odyssey Slide 2" 
        class="slide-img absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out" 
      />
      <!-- Image 3 -->
      <img 
        src="/images/drone/drone-albania-2.JPG" 
        alt="The Odyssey Slide 3" 
        class="slide-img absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out" 
      />
      <div class="absolute inset-0 bg-gradient-to-b from-neutral-950/20 via-transparent to-[#FAF9F6]/25 z-10"></div>
    </div>

    <!-- TEXTE FIXE MAGAZINE -->
    <div class="relative z-20 max-w-4xl mx-auto text-white space-y-4">
      <span class="text-[10px] font-mono tracking-[0.5em] uppercase text-neutral-200 block drop-shadow-xs">Slow Travel Magazine</span>
      <h1 class="text-4xl sm:text-7xl font-serif font-light tracking-tight leading-[1.15] drop-shadow-md">
        Prendre le temps de<br/><span class="italic font-normal text-neutral-100">découvrir le monde.</span>
      </h1>
      <p class="text-neutral-200 max-w-md mx-auto text-[10px] font-mono tracking-widest uppercase pt-4 drop-shadow-xs">
        Guides complets de 1 à 2 semaines pour explorateurs libres
      </p>
    </div>
  </section>

  <!-- LISTE DES GUIDES (GRILLE DE 4 CARTES PAR LIGNE) -->
  <section id="destinations" class="max-w-[95%] mx-auto px-4 py-20 border-t border-neutral-200/60 scroll-mt-20">
    <span class="text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-400 block mb-12 text-center sm:text-left">Nos Itinéraires au Long Cours</span>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-16">
      <!-- CARD 1 : ALBANIE -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">1 Semaine</span>
          <img src="/images/drone/drone-albania-5.JPG" alt="Guide Itinéraire Albanie" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Europe // Balkans</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Albanie : Riviera & Parcs</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">De Tirana aux plages sauvages de Ksamil. Un road-trip équilibré d'une semaine complète entre villages de pierre et criques cachées.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Logements conseillés</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM Albanie (-5%)</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

      <!-- CARD 2 : LA CORSE -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">2 Semaines</span>
          <img src="https://unsplash.com" alt="Guide Corse" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Europe // France</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Corse : L'Île de Beauté</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">15 jours des calanques de Piana aux falaises de Bonifacio. Les plus belles aiguilles de Bavella et criques d'eau turquoise.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Réserver ses bergeries</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM Corse</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

      <!-- CARD 3 : CHICAGO -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">1 Semaine</span>
          <img src="https://unsplash.com" alt="Guide Chicago" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Amérique // USA</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Chicago : Architecture</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">Une semaine immersive le long du Michigan. Exploration des gratte-ciels cultes, du Millenium Park et des clubs de jazz historiques.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Hôtels Downtown Chicago</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM USA (-5%)</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

      <!-- CARD 4 : MIAMI -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">2 Semaines</span>
          <img src="https://unsplash.com" alt="Guide Miami" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Amérique // USA</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Miami & Floride : Le Soleil</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">15 jours de South Beach aux marais des Everglades. Itinéraire magique sur l'Overseas Highway jusqu'au bout de Key West.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Boutiques hôtels Miami</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM Floride</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>
      <!-- CARD 5 : SAINT-TROPEZ -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">1 Semaine</span>
          <img src="https://unsplash.com" alt="Guide Saint-Tropez" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">

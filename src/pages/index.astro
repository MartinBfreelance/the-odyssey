    <!-- GRILLE DE FLUX INSTAGRAM RECONNAISSABLE -->
    <div class="pt-8 border-t border-neutral-200/40 space-y-4">
      <div class="text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-400">— INSTAGRAM —</div>
      
      <div class="flex items-center justify-center space-x-3 py-2">
        <div class="w-9 h-9 rounded-full bg-gradient-to-tr from-amber-500 via-red-500 to-purple-600 p-[2px]">
          <div class="w-full h-full bg-white rounded-full flex items-center justify-center font-bold text-xs text-neutral-900">📸</div>
        </div>
        <span class="text-xs font-bold text-neutral-900 tracking-wide">@the_odyssey_magazine</span>
      </div>

      <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="inline-block text-[10px] font-mono uppercase tracking-widest bg-sky-500 text-white font-bold px-6 py-2.5 rounded-md hover:bg-neutral-900 transition-colors shadow-2xs">
        Follow on Instagram
      </a>

      <!-- Les 9 petites vignettes photos style Instagram -->
      <div class="grid grid-cols-3 gap-2 max-w-sm mx-auto pt-4">
        <div class="aspect-square bg-neutral-100 overflow-hidden"><img src="/images/drone/drone-albania-5.JPG" class="w-full h-full object-cover" /></div>
        <div class="aspect-square bg-neutral-100 overflow-hidden"><img src="https://unsplash.com" class="w-full h-full object-cover" /></div>
        <div class="aspect-square bg-neutral-100 overflow-hidden"><img src="https://unsplash.com" class="w-full h-full object-cover" /></div>
        <div class="aspect-square bg-neutral-100 overflow-hidden"><img src="/images/drone/drone-albania-1.JPG" class="w-full h-full object-cover" /></div>
        <div class="aspect-square bg-neutral-100 overflow-hidden"><img src="/images/drone/drone-albania-2.JPG" class="w-full h-full object-cover" /></div>
        <div class="aspect-square bg-neutral-100 overflow-hidden"><img src="https://unsplash.com" class="w-full h-full object-cover" /></div>
        <div class="aspect-square bg-neutral-100 overflow-hidden"><img src="https://unsplash.com" class="w-full h-full object-cover" /></div>
        <div class="aspect-square bg-neutral-100 overflow-hidden"><img src="https://unsplash.com" class="w-full h-full object-cover" /></div>
        <div class="aspect-square bg-neutral-100 overflow-hidden"><img src="https://unsplash.com" class="w-full h-full object-cover" /></div>
      </div>
    </div>
  </section>
  <!-- SECTION MONÉTISATION PRINCIPALE -->
  <section id="bons-plans" class="max-w-4xl mx-auto px-8 py-16 bg-neutral-950 text-white rounded-none my-16 border-t-4 border-amber-600">
    <div class="space-y-12">
      <div class="space-y-3">

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="THE ODYSSEY | Slow Travel Magazine & Guides Complets">
  
  <!-- HERO SLIDER PLEIN ÉCRAN + EFFET DE GRADIENT COURT ET LISSÉ DE BOKO STUDIO -->
  <section class="relative h-screen w-full bg-neutral-950 flex items-center justify-center text-center px-6 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="/images/drone/drone-albania-5.JPG" 
        alt="The Odyssey Slide 1" 
        class="slide-img absolute inset-0 w-full h-full object-cover opacity-65 transition-opacity duration-1000 ease-in-out" 
      />
      <img 
        src="/images/drone/drone-albania-1.JPG" 
        alt="The Odyssey Slide 2" 
        class="slide-img absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out" 
      />
      <img 
        src="/images/drone/drone-albania-2.JPG" 
        alt="The Odyssey Slide 3" 
        class="slide-img absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out" 
      />
      
      <!-- MASQUE DE SURROUND NOIR TRANSITORY (Empêche le blanc de remonter trop haut sur l'image) -->
      <div class="absolute inset-0 bg-gradient-to-b from-neutral-950/20 via-transparent to-neutral-950/30 z-10"></div>
      
      <!-- FADE DE TRANSITION ULTRA COURT TOUT EN BAS VERS LE FOND IVOIRE (STYLE EXACT BOKO) -->
      <div class="absolute bottom-0 left-0 right-0 h-[25vh] bg-gradient-to-b from-transparent to-[#FAF9F6] z-10"></div>
    </div>

    <!-- TEXTE INTEGRÉ DANS LE SLIDER IMMERSIF -->
    <div class="relative z-20 max-w-4xl mx-auto text-white space-y-4">
      <span class="text-[10px] font-mono tracking-[0.5em] uppercase text-neutral-200 block drop-shadow-xs">Slow Travel Magazine</span>
      <h1 class="text-4xl sm:text-7xl font-serif font-light tracking-tight leading-[1.15] drop-shadow-md">
        Prendre le temps de<br/><span class="italic font-normal text-neutral-100">découvrir le monde.</span>
      </h1>
      <p class="text-neutral-200 max-w-md mx-auto text-[10px] font-mono tracking-widest uppercase pt-4 drop-shadow-xs">
        Guides complets de 1 à 2 semaines pour explorateurs libres
      </p>
    </div>
  </section>
  <!-- LISTE DES GUIDES COMPLETS ALIGNÉE -->
  <section id="destinations" class="max-w-7xl mx-auto px-8 py-20 border-t border-neutral-200/60 scroll-mt-20">
    
    <!-- TITRE DE SECTION AVEC ICONE SIGNATURE BOUSSOLE INTERACTIVE -->
    <div class="flex items-center space-x-3 mb-12 justify-center sm:justify-start group/section-title cursor-default">
      <div class="w-4 h-4 text-amber-600 group-hover/section-title:rotate-45 group-hover/section-title:text-amber-500 transition-all duration-500 ease-out">
        <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="2"></path>
          <path fill="currentColor" d="M12 7l1.5 3.5L12 12l-1.5-1.5zM12 17l1.5-3.5L12 12l-1.5 1.5z"></path>
        </svg>
      </div>
      <span class="text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-400 group-hover/section-title:text-amber-700 transition-colors duration-300">
        Nos Itinéraires au Long Cours
      </span>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-16">
      
      <!-- CARD 1 : ALBANIE -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">1 Semaine</span>
          <img src="/images/drone/drone-albania-5.JPG" alt="Guide Itinéraire Albanie" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Europe // Balkans</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Albanie : Riviera & Parcs</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">De Tirana aux plages sauvages de Ksamil. Un road-trip équilibré d'une semaine complète entre villages de pierre et criques cachées.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Logements conseillés</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM Albanie (-5%)</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

      <!-- CARD 2 : LA CORSE -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">2 Semaines</span>
          <img src="https://unsplash.com" alt="Guide Corse" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Europe // France</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Corse : L'Île de Beauté</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">15 jours des calanques de Piana aux falaises de Bonifacio. Les plus belles aiguilles de Bavella et criques d'eau turquoise.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Réserver ses bergeries</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM Corse</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>
      <!-- CARD 3 : CHICAGO -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">1 Semaine</span>
          <img src="https://unsplash.com" alt="Guide Chicago" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Amérique // USA</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Chicago : Architecture</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">Une semaine immersive le long du Michigan. Exploration des gratte-ciels cultes, du Millenium Park et des clubs de jazz historiques.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Hôtels Downtown Chicago</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM USA (-5%)</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

      <!-- CARD 4 : MIAMI -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">2 Semaines</span>
          <img src="https://unsplash.com" alt="Guide Miami" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Amérique // USA</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Miami & Floride : Le Soleil</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">15 jours de South Beach aux marais des Everglades. Itinéraire magique sur l'Overseas Highway jusqu'au bout de Key West.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Boutiques hôtels Miami</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM Floride</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

      <!-- CARD 5 : SAINT-TROPEZ -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">1 Semaine</span>
          <img src="https://unsplash.com" alt="Guide Saint-Tropez" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Europe // France</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Saint-Tropez & Var</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">Une semaine de douceur de vivre. Des ruelles de la Ponche aux sentiers côtiers de Ramatuelle et vignobles cachés du Var.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Logements de charme</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM France</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>
      <!-- CARD 6 : BORDEAUX -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">1 Semaine</span>
          <img src="/images/drone/drone-albania-5.JPG" alt="Guide Bordeaux" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Europe // France</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Bordeaux & Vignobles</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">7 jours d'immersion culturelle. Splendeurs architecturales de la ville de pierre, Cité du Vin et escapades à Saint-Émilion.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Hôtels Centre Historique</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM Europe</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

      <!-- CARD 7 : BASSIN D'ARCACHON -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">1 Semaine</span>
          <img src="https://unsplash.com" alt="Guide Arcachon" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Europe // France</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Le Bassin d'Arcachon</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">Une semaine iodée. Ascension de la Dune du Pilat, dégustation d'huîtres dans les cabanes ostréicoles et Cap Ferret.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Réserver ses cabanes</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM France</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

      <!-- CARD 8 : BIARRITZ -->
      <article class="group flex flex-col justify-between h-full bg-white border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">2 Semaines</span>
          <img src="https://unsplash.com" alt="Guide Biarritz" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-1.5">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block">Europe // France</span>
            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Biarritz & Le Pays Basque</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">15 jours majeurs entre vagues de l'Océan Atlantique, sessions de surf, et immersion dans les villages d'Espelette.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Hôtels Côte Basque</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM France</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

    </div>
  </section>
  <!-- SECTION PRÉSENTATION CORRIGÉE : PARFAITEMENT ALIGNÉE GAUCHE/DROITE (MAX-W-7XL) -->
  <section class="max-w-7xl mx-auto px-8 py-24 border-t border-neutral-200/60 flex flex-col lg:flex-row items-start justify-between gap-16">
    
    <!-- COLONNE GAUCHE : PHOTO ENTIÈRE + TEXTE MANIFESTE -->
    <div class="w-full lg:w-[48%] space-y-8">
      <div class="w-full h-[320px] overflow-hidden bg-neutral-100 rounded-sm shadow-2xs">
        <img 
          src="/images/drone/drone-albania-1.JPG" 
          class="w-full h-full object-cover" 
          alt="The Odyssey Exploration" 
        />
      </div>

      <!-- TEXTE DE BIENVENUE AVEC MINI-BOUSSOLE INTERACTIVE -->
      <div class="space-y-6">
        <div class="space-y-2 group/manifesto-title cursor-default">
          <div class="flex items-center space-x-3">
            <div class="w-4 h-4 text-amber-600 group-hover/manifesto-title:rotate-45 group-hover/manifesto-title:text-amber-500 transition-all duration-500 ease-out">
              <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="2"></path>
                <path fill="currentColor" d="M12 7l1.5 3.5L12 12l-1.5-1.5zM12 17l1.5-3.5L12 12l-1.5 1.5z"></path>
              </svg>
            </div>
            <span class="text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-400 group-hover/manifesto-title:text-amber-700 transition-colors duration-300">
              Notre Manifeste
            </span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-serif font-light text-neutral-900 tracking-tight leading-tight">MARTIN — THE ODYSSEY</h2>
          <p class="text-[10px] font-mono text-amber-700 uppercase tracking-widest italic">Créateur de Contenu & Écriture Photographique</p>
        </div>
        
        <p class="text-xs text-neutral-500 font-light leading-relaxed">
          Bonjour ! J'ai imaginé le slow magazine **The Odyssey** pour partager des itinéraires au long cours de 1 à 2 semaines, construits pas à pas, ainsi que pour transmettre ma passion de la découverte indépendante. 
        </p>
        <p class="text-xs text-neutral-500 font-light leading-relaxed">
          Ici, pas de survol rapide : chaque tracé fait l'objet d'une immersion approfondie, de conseils de guesthouses confidentielles et de clichés pris au lever du jour. L'aventure se prolonge également en direct avec notre communauté sur Instagram ❤️
        </p>
      </div>
    </div>

    <!-- COLONNE DROITE : LE FLUX INSTAGRAM PUR -->
    <div class="w-full lg:w-[45%] bg-white border border-neutral-200/50 p-8 rounded-sm shadow-2xs space-y-6 text-center">
      <div class="space-y-4">
        <div class="flex items-center justify-center space-x-3">
          <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-amber-500 via-red-500 to-purple-600 p-[2px]">
            <div class="w-full h-full bg-white rounded-full flex items-center justify-center text-xs">📸</div>
          </div>
          <span class="text-xs font-bold text-neutral-900 tracking-wide">@the_odyssey_magazine</span>
        </div>

        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="inline-block text-[10px] font-mono uppercase tracking-[0.25em] bg-sky-500 text-white font-bold px-8 py-3 rounded-md hover:bg-neutral-900 transition-colors shadow-2xs w-full sm:w-auto">
          Follow on Instagram
        </a>
      </div>

      <div class="grid grid-cols-3 gap-2 pt-4">
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-5.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="https://unsplash.com" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="https://unsplash.com" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-1.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-2.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="https://unsplash.com" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>

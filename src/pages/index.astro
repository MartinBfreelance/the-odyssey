<script type="text/javascript">
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('destination-search');
    const compactSelect = document.getElementById('compact-filter');
    const needle = document.getElementById('compass-needle');
    const pageDisplay = document.getElementById('page-display');
    const prevCompass = document.getElementById('prev-compass');
    const nextCompass = document.getElementById('next-compass');
    const cards = document.querySelectorAll('.guide-card');

    let currentFilter = 'all';
    let searchQuery = '';
    let currentPage = 1;
    let cardsPerPage = 8;
    let visibleCards = [];

    const romanNumerals = ["", "I", "II", "III", "IV"];

    function checkDeviceWidth() {
      if (window.innerWidth < 640) {
        cardsPerPage = 4;
      } else {
        cardsPerPage = 8;
      }
    }
    checkDeviceWidth();
    window.addEventListener('resize', () => { checkDeviceWidth(); updatePagination(); });

    const items = new Set();
    cards.forEach(card => {
      if(card.dataset.continent) items.add(card.dataset.continent);
      if(card.dataset.country === "Russie" || card.dataset.country === "Japon") items.add(card.dataset.country);
    });

    let selectHTML = `<option value="all">Explorer le globe (Tous)</option>`;
    items.forEach(item => {
      const slug = item.toLowerCase().replace(/[^a-z0-9]/g, '');
      selectHTML += `<option value="${slug}">${item}</option>`;
    });
    if(compactSelect) compactSelect.innerHTML = selectHTML;

    function updatePagination() {
      visibleCards = Array.from(cards).filter(card => {
        const continentSlug = card.dataset.continent.toLowerCase().replace(/[^a-z0-9]/g, '');
        const countrySlug = card.dataset.country ? card.dataset.country.toLowerCase().replace(/[^a-z0-9]/g, '') : '';
        const matchesSelect = (currentFilter === 'all' || continentSlug === currentFilter || countrySlug === currentFilter);
        const matchesSearch = card.dataset.search.includes(searchQuery);
        return matchesSelect && matchesSearch;
      });

      const totalPages = Math.ceil(visibleCards.length / cardsPerPage) || 1;
      if (currentPage > totalPages) currentPage = totalPages;

      cards.forEach(card => { card.style.display = 'none'; card.style.opacity = '0'; });
      const start = (currentPage - 1) * cardsPerPage;
      visibleCards.slice(start, start + cardsPerPage).forEach(card => {
        card.style.display = 'flex';
        setTimeout(() => card.style.opacity = '1', 50);
      });

      const roman = romanNumerals[currentPage] || currentPage;
      if(pageDisplay) pageDisplay.innerText = `THE ODYSSEY // PAGE ${roman}`;

      if(totalPages === 1) {
        prevCompass.style.opacity = '0.25'; prevCompass.style.pointerEvents = 'none';
        nextCompass.style.opacity = '0.25'; nextCompass.style.pointerEvents = 'none';
        needle.style.transform = 'rotate(0deg)';
      } else {
        prevCompass.style.opacity = currentPage === 1 ? '0.25' : '1';
        prevCompass.style.pointerEvents = currentPage === 1 ? 'none' : 'auto';
        nextCompass.style.opacity = currentPage === totalPages ? '0.25' : '1';
        nextCompass.style.pointerEvents = currentPage === totalPages ? 'none' : 'auto';
      }
    }

    if(prevCompass && nextCompass && needle) {
      prevCompass.addEventListener('mouseenter', () => { if(currentPage > 1) needle.style.transform = 'rotate(-30deg)'; });
      prevCompass.addEventListener('mouseleave', () => needle.style.transform = 'rotate(0deg)');
      nextCompass.addEventListener('mouseenter', () => { if(currentPage < Math.ceil(visibleCards.length / cardsPerPage)) needle.style.transform = 'rotate(30deg)'; });
      nextCompass.addEventListener('mouseleave', () => needle.style.transform = 'rotate(0deg)');
      
      prevCompass.addEventListener('click', () => { 
        if (currentPage > 1) { 
          currentPage--; 
          updatePagination(); 
          needle.style.transform = 'rotate(-60deg)'; 
          setTimeout(() => needle.style.transform = 'rotate(0deg)', 250); 
        } 
      });
      nextCompass.addEventListener('click', () => { 
        if (currentPage < Math.ceil(visibleCards.length / cardsPerPage)) { 
          currentPage++; 
          updatePagination(); 
          needle.style.transform = 'rotate(60deg)'; 
          setTimeout(() => needle.style.transform = 'rotate(0deg)', 250); 
        } 
      });
    }

    if(searchInput) searchInput.addEventListener('input', (e) => { searchQuery = e.target.value.toLowerCase().trim(); currentPage = 1; updatePagination(); });
    if(compactSelect) compactSelect.addEventListener('change', (e) => { currentFilter = e.target.value; currentPage = 1; updatePagination(); });

    updatePagination();

    const images = document.querySelectorAll('.slide-img');
    let currentIndex = 0;
    if(images.length > 0) {
      setInterval(() => {
        images[currentIndex].style.opacity = '0';
        currentIndex = (currentIndex + 1) % images.length;
        images[currentIndex].style.opacity = '0.6';
      }, 3000);
    }
  });
</script>

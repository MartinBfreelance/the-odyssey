---
import Layout from '../layouts/Layout.astro';
import destinationsData from '../data/destinations.json';
---

<Layout title="THE ODYSSEY | Slow Travel Journal & Guide">
  
  <!-- HERO SLIDER PLEIN ÉCRAN -->
  <section class="relative h-screen w-full bg-[#0A0A0A] flex items-center justify-center text-center px-4 sm:px-6 overflow-hidden">
    <div class="absolute inset-0 z-0 pointer-events-none select-none">
      {destinationsData.slice(0, 3).map((dest, idx) => (
        <img 
          src={dest.image} 
          alt={dest.titre} 
          class={`slide-img absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ease-in-out ${idx === 0 ? 'opacity-65' : 'opacity-0'}`} 
        />
      ))}
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#FAF9F6] z-10"></div>
    </div>

    <!-- ZONE DE TEXTE INTÉGRÉE (AVEC CONTRASTE BICOLORE) -->
    <div class="relative z-20 w-full max-w-4xl mx-auto text-white space-y-4 px-2">
      <span class="text-[10px] font-mono tracking-[0.5em] uppercase text-neutral-200 block drop-shadow-xs">Slow Travel Journal</span>
      <h1 class="text-3xl sm:text-5xl md:text-7xl font-serif font-light tracking-tight leading-[1.2] drop-shadow-md">
        Take the time to<br/><span class="italic font-normal text-amber-500">discover the world.</span>
      </h1>
      <p class="text-neutral-200/90 max-w-md mx-auto text-[9px] sm:text-[10px] font-mono tracking-widest uppercase pt-2 sm:pt-4 drop-shadow-xs">
        Complete guides from one explorer to another
      </p>
    </div>
  </section>

  <!-- SECTION DESTINATIONS (AVEC OVERFLOW-HIDDEN SUR ARTICLE MAIS OVERFLOW-VISIBLE ICI) -->
  <section id="destinations" class="w-full max-w-[1600px] mx-auto px-4 sm:px-8 md:px-12 py-16 sm:py-20 border-t border-neutral-200/60 scroll-mt-20 overflow-visible">
    
    <!-- EN-TÊTE ULTRA-RESPONSIVE (TITRE SEUL) -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-8 border-b border-neutral-200/40 pb-8">
      
      <!-- TITRE DE SECTION COMPASS NOIR AJUSTÉ EN TAILLE -->
      <div class="flex items-center space-x-3 group/section-title cursor-default text-center sm:text-left">
        <div class="w-5 h-5 text-neutral-400 group-hover/section-title:rotate-45 group-hover/section-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5" stroke="currentColor"></circle>
            <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
            <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
            <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
          </svg>
        </div>
        <span class="relative text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-950 font-bold group-hover/section-title:text-amber-800 transition-colors duration-300">
          Nos Itinéraires au Long Cours
          <span class="absolute bottom-0 left-0 w-0 h-[4px] bg-amber-500/15 group-hover/section-title:w-full transition-all duration-500 ease-out rounded-xs"></span>
        </span>
      </div>
    </div>

    <!-- BANDEAU GÉOMÉTRIQUE RIGIDE 12 COLONNES (ZÉRO DÉCALAGE DE PIXEL) -->
    <div class="w-full grid grid-cols-1 lg:grid-cols-12 gap-6 items-center mb-10 p-5 sm:p-6 bg-white border border-neutral-200/50 rounded-3xl shadow-2xs font-mono text-[9px] tracking-wider select-none relative z-20">
      
      <!-- Colonnes 1 à 6 (50% de la largeur) : Boutons d'Ambiance et de Profil (à gauche, alignement vertical parfait des icônes) -->
      <div class="lg:col-span-6 flex flex-col gap-4">
        <!-- Ambiance -->
        <div id="filter-group-type" class="flex items-center gap-1.5 sm:gap-2 w-full">
          <span class="w-20 font-bold text-neutral-400 uppercase shrink-0">Ambiance :</span>
          <div class="flex flex-wrap items-center gap-1.5 sm:gap-2">
            <button data-type-filter="all" class="filter-btn-type px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer">Tous</button>
            <button data-type-filter="aventure" class="filter-btn-type px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer flex items-center gap-1.5">
              <span>🥾</span><span>Aventure & Trek</span>
            </button>
            <button data-type-filter="plages" class="filter-btn-type px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer flex items-center gap-1.5">
              <span>🏖️</span><span>Plage & Farniente</span>
            </button>
            <button data-type-filter="culture" class="filter-btn-type px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer flex items-center gap-1.5">
              <span>🏛️</span><span>Villes & Culture</span>
            </button>
          </div>
        </div>

        <!-- Profil voyageur -->
        <div id="filter-group-profil" class="flex items-center gap-1.5 sm:gap-2 w-full">
          <span class="w-20 font-bold text-neutral-400 uppercase shrink-0">Profil :</span>
          <div class="flex flex-wrap items-center gap-1.5 sm:gap-2">
            <button data-profil-filter="all" class="filter-btn-profil px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer">Tous</button>
            <button data-profil-filter="couple" class="filter-btn-profil px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer flex items-center gap-1.5">
              <span>👫</span><span>Couple</span>
            </button>
            <button data-profil-filter="famille" class="filter-btn-profil px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer flex items-center gap-1.5">
              <span>👨‍👩‍👧</span><span>Famille</span>
            </button>
            <button data-profil-filter="solo" class="filter-btn-profil px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer flex items-center gap-1.5">
              <span>🧍</span><span>Solo</span>
            </button>
            <button data-profil-filter="amis" class="filter-btn-profil px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer flex items-center gap-1.5">
              <span>👥</span><span>Amis</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Colonnes 7 à 10 (33.3% de la largeur) : Recherche et Menu déroulant délimités par des séparateurs rigides -->
      <div class="lg:col-span-4 flex flex-col sm:flex-row gap-3 items-center w-full lg:border-l lg:border-r lg:border-neutral-200/80 lg:px-6">
        <!-- Input Recherche -->
        <div class="relative w-full">
          <input 
            type="text" 
            id="destination-search" 
            placeholder="Rechercher..." 
            autocomplete="off"
            maxlength="100"
            class="w-full bg-[#FFFFFF] border border-neutral-200/80 px-3 py-2.5 pl-8 text-[11px] font-mono uppercase tracking-wider text-neutral-800 placeholder-neutral-400 focus:outline-hidden focus:border-amber-600 rounded-lg transition-colors shadow-2xs"
          />
          <span class="absolute left-2.5 top-3.5 text-neutral-400 text-[10px]">🔍</span>
        </div>
        
        <!-- Menu Déroulant Compact -->
        <div class="relative w-full sm:w-auto shrink-0">
          <select 
            id="compact-filter" 
            class="w-full sm:w-auto bg-[#FFFFFF] border border-neutral-200/80 px-4 py-2.5 pr-8 text-[11px] font-mono uppercase tracking-widest text-neutral-700 focus:outline-hidden focus:border-amber-600 rounded-lg transition-colors shadow-2xs appearance-none cursor-pointer"
          >
          </select>
          <span class="absolute right-3 top-3.5 text-[8px] text-neutral-400 pointer-events-none">▼</span>
        </div>
      </div>

      <!-- Colonnes 11 à 12 (16.6% de la largeur) : Nombre de destinations (bloqué horizontalement) -->
      <div class="lg:col-span-2 text-right w-full lg:pl-6 shrink-0 font-mono text-[9px] tracking-widest">
        <div class="text-neutral-500 font-medium whitespace-nowrap text-center lg:text-left">
          <span class="inline-block w-5 text-center font-bold text-neutral-900 text-xs sm:text-sm">
            <span id="results-count">0</span>
          </span> destinations
        </div>
      </div>
    </div>
    
    <!-- CONTENEUR GRILLE RE-DESIGNÉ (3 COLONNES MAX TYPE VOYAGE PRIVÉ) -->
    <div id="guides-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12 transition-all duration-500">
      {destinationsData.map((dest) => (
        <article 
          class="guide-card group flex flex-col justify-between h-full bg-[#FFFFFF] border border-neutral-200/40 rounded-2xl overflow-hidden shadow-2xs hover:shadow-md transition-all duration-500 ease-out w-full mx-auto" 
          data-id={dest.slug} 
          data-continent={dest.continent} 
          data-country={dest.geo.split(' // ').pop()} 
          data-search={`${dest.continent} ${dest.geo.toLowerCase()} ${dest.titre.toLowerCase()} ${dest.sous_titre.toLowerCase()}`}
        >
          <div class="w-full aspect-[16/9] overflow-hidden bg-neutral-100 relative">
            <img src={dest.image} alt={dest.titre} class="w-full h-full object-cover rounded-t-2xl group-hover:scale-101 transition-transform duration-1000 ease-out" />
            <!-- Bouton Cœur positionné en haut à droite (top-3/right-3) avec fond glassmorphism discret -->
            <button class="fav-btn absolute top-3 right-3 z-30 p-2.5 rounded-full bg-white/10 border border-white/20 backdrop-blur-md text-white/90 hover:scale-110 active:scale-95 transition-all duration-300 shadow-sm cursor-pointer" aria-label="Ajouter aux favoris">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 transition-all duration-300">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
            </button>
          </div>
          <div class="p-6 flex-grow flex flex-col justify-between space-y-4">
            <div class="space-y-2">
              <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block font-medium">{dest.geo}</span>
              <h2 class="text-base sm:text-lg font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">{dest.titre}</h2>
              <p class="text-[11px] sm:text-xs text-neutral-500 font-light leading-relaxed">{dest.sous_titre}</p>
            </div>
            <div class="pt-4 border-t border-neutral-100 space-y-2 text-[10px] font-mono">
              <a href={dest.liens.booking} target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Trouver son logement</a>
              <a href={dest.liens.esim} target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM Nomad</a>
              <a href={`/destinations/${dest.slug}`} class="dest-link pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer flex items-center gap-1.5">
                Découvrir <span class="inline-block transition-transform duration-300 ease-out group-hover:translate-x-1.5">→</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- MODULE SLIDER COMPASS COMPACT RE-HAUSSÉ -->
    <div class="w-full flex flex-col items-center justify-center mt-12 select-none overflow-hidden px-4">
      <div class="flex items-center space-x-10 text-[10px] sm:text-[11px] font-mono uppercase tracking-[0.3em] text-neutral-400">
        
        <!-- Bouton West Fixe (Surlignage Ambre interactif) -->
        <button id="prev-compass" class="flex items-center space-x-2.5 hover:text-amber-600 transition-colors duration-300 cursor-pointer group/prev disabled:opacity-25 disabled:cursor-not-allowed shrink-0 font-bold tracking-[0.4em]">
          <span class="transform group-hover/prev:-translate-x-1 transition-transform duration-300">↼</span>
          <span class="inline">West</span>
        </button>

        <!-- LOGO SLIDER COMPASS -->
        <div id="compass-needle" class="w-14 h-14 text-neutral-800 transition-all duration-500 ease-out flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
            <circle cx="12" cy="12" r="10" stroke="currentColor"></circle>
            <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5" stroke="currentColor"></circle>
            <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
            <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
            <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
          </svg>
        </div>

        <!-- Bouton East Fixe (Surlignage Ambre interactif) -->
        <button id="next-compass" class="flex items-center space-x-2.5 hover:text-amber-600 transition-colors duration-300 cursor-pointer group/next disabled:opacity-25 disabled:cursor-not-allowed shrink-0 font-bold tracking-[0.4em]">
          <span class="inline">East</span>
          <span class="transform group-hover/next:translate-x-1 transition-transform duration-300">⇁</span>
        </button>
      </div>
      
      <!-- Étiquette Épurée Édimestre -->
      <div class="mt-4 text-[10px] sm:text-[11px] font-serif tracking-[0.35em] text-neutral-400 font-light italic text-center" id="page-display">THE ODYSSEY // PAGE I</div>
    </div>

  </section>

  <!-- SECTION PRÉSENTATION ADAPTÉE À L'ENSEMBLE DES ÉCRANS -->
  <section class="w-full max-w-[1600px] mx-auto px-4 sm:px-8 md:px-12 py-20 border-t border-neutral-200/60 flex flex-col lg:flex-row items-start justify-between gap-12 lg:gap-16 overflow-hidden">
    
    <!-- COLONNE GAUCHE : PHOTO ENTIÈRE + TEXTE MANIFESTE ANIMÉ -->
    <div class="w-full lg:w-[48%] space-y-6 sm:space-y-8">
      <div class="w-full h-[260px] sm:h-[350px] md:h-[400px] overflow-hidden bg-neutral-100 rounded-sm shadow-2xs">
        <img src="/images/drone/drone-albania-1.JPG" class="w-full h-full object-cover" alt="The Odyssey Exploration" />
      </div>

      <!-- TITRE DE SECTION COMPRESSED ET ANIMATION DU TITRE SERIF -->
      <div class="space-y-6 group/manifesto-heading cursor-default">
        <div class="space-y-2">
          <div class="flex items-center space-x-3 justify-center lg:justify-start group/manifesto-title cursor-default">
            <!-- Boussole d'origine verticalisée pointant vers le haut, animée en rotation et ambre au survol -->
            <div class="w-5 h-5 text-neutral-400 group-hover/manifesto-title:rotate-45 group-hover/manifesto-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5" stroke="currentColor"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <!-- Titre en noir absolu text-neutral-950 et taille reduite text-[9px] -->
            <span class="relative text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-950 font-bold group-hover/manifesto-title:text-amber-800 transition-colors duration-300">
              Notre Manifeste
              <span class="absolute bottom-0 left-0 w-0 h-[4px] bg-amber-500/15 group-hover/manifesto-title:w-full transition-all duration-500 ease-out rounded-xs"></span>
            </span>
          </div>
          
          <!-- Titre principal qui s'anime au survol -->
          <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-serif font-light text-neutral-900 tracking-tight leading-tight text-center lg:text-left transition-all duration-700 ease-out group-hover/manifesto-heading:text-amber-700 group-hover/manifesto-heading:translate-x-1.5">
            The Odyssey — Martin & Flo
          </h2>
          <p class="text-[10px] font-mono text-amber-700 uppercase tracking-widest italic text-center lg:text-left transition-all duration-700 ease-out group-hover/manifesto-heading:tracking-[0.25em]">
            Carnets de route & Récits photographiques
          </p>
        </div>
        
        <p class="text-xs text-neutral-500 font-light leading-relaxed text-center lg:text-left">
          Bonjour ! Nous sommes Martin et Florence. Nous avons imaginé le slow journal **The Odyssey** pour qu'il devienne votre compagnon de route, à la manière d'un guide de voyage indépendant, libre et sincère.
        </p>
        <p class="text-xs text-neutral-500 font-light leading-relaxed text-center lg:text-left">
          Ici, pas de survol rapide ou de recommandations sponsorisées. Chaque tracé fait l'objet d'une immersion vécue, de guesthouses confidentielles dénichées pas à pas et de clichés pris sur le vif. Pour financer notre travail en toute transparence, nous recommandons uniquement des services que nous utilisons nous-mêmes sur le terrain (comme Nomad ou Chapka). Notre but est de vous donner les clés pour explore le monde à votre propre rythme. L'aventure continue au jour le jour avec notre communauté sur Instagram ❤️
        </p>
      </div>
    </div>

    <!-- COLONNE DROITE : LE FLUX INSTAGRAM -->
    <div class="w-full lg:w-[46%] bg-[#FFFFFF] border border-neutral-200/50 p-6 sm:p-10 rounded-sm shadow-2xs space-y-6 text-center">
      
      <!-- Titre de section boussole animée pour Instagram en noir absolu -->
      <div class="flex items-center justify-center space-x-3 group/insta-title cursor-default mt-6 mb-8">
        <div class="w-5 h-5 text-neutral-400 group-hover/insta-title:rotate-45 group-hover/insta-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5" stroke="currentColor"></circle>
            <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
            <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
            <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
          </svg>
        </div>
        <span class="relative text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-950 font-bold group-hover/insta-title:text-amber-800 transition-colors duration-300">
          Notre Communauté
          <span class="absolute bottom-0 left-0 w-0 h-[4px] bg-amber-500/15 group-hover/insta-title:w-full transition-all duration-500 ease-out rounded-xs"></span>
        </span>
      </div>

      <!-- BANDEAU HORIZONTAL INSTAGRAM ALIGNÉ -->
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 border-b border-neutral-100 pb-6 text-left">
        <!-- Identifiant + VRAI Logo Instagram (à gauche) -->
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-amber-500 via-red-500 to-purple-600 p-[2px] shrink-0 flex items-center justify-center">
            <div class="w-full h-full bg-[#FFFFFF] rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-neutral-800">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </div>
          </div>
          <span class="text-xs font-bold text-neutral-900 tracking-wide">@the_odyssey_travel_journal</span>
        </div>

        <!-- Bouton Follow (à droite) -->
        <a 
          href="https://instagram.com/the_odyssey_travel_journal" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-[9px] sm:text-[10px] font-mono uppercase tracking-[0.15em] bg-sky-500 hover:bg-neutral-900 text-white font-bold px-6 py-2.5 rounded-md transition-colors shadow-2xs shrink-0 whitespace-nowrap text-center w-full sm:w-auto"
        >
          Follow on Instagram
        </a>
      </div>

      <div class="grid grid-cols-3 gap-2 sm:gap-3 pt-4">
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-5.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-1.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-2.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-1.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-2.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-5.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-2.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-5.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
        <div class="aspect-square overflow-hidden bg-neutral-100"><img src="/images/drone/drone-albania-1.JPG" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" /></div>
      </div>
    </div>
  </section>
  

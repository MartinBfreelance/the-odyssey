            <h2 class="text-base font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Biarritz & Le Pays Basque</h2>
            <p class="text-[11px] text-neutral-500 font-light leading-relaxed">15 jours majeurs entre vagues de l'Océan Atlantique, sessions de surf, et immersion dans les villages d'Espelette.</p>
          </div>
          <div class="pt-3 border-t border-neutral-100 space-y-2 text-[9px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Hôtels Côte Basque</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM France</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

    </div>
  </section>
  <!-- SECTION PRÉSENTATION & INSTAGRAM (STYLE IDENTIQUE À TA CAPTURE D'ÉCRAN) -->
  <section class="max-w-xl mx-auto px-6 py-20 text-center space-y-8 border-t border-neutral-200/60">
    
    <!-- PHOTO RECOMPOSÉE EN DIAGONALE PREMIUM -->
    <div class="relative w-full h-[380px] overflow-hidden bg-neutral-100 shadow-2xs">
      <div class="absolute inset-0 flex">
        <!-- Photo de gauche (Aurélie) -->
        <div class="w-1/2 h-full overflow-hidden [clip-path:polygon(0_0,100%_0,0_100%)]">
          <img src="/images/drone/drone-albania-1.JPG" class="w-full h-full object-cover scale-110" alt="The Odyssey Left" />
        </div>
        <!-- Photo de droite (Yann) -->
        <div class="w-1/2 h-full overflow-hidden [clip-path:polygon(100%_0,100%_100%,0_100%)] -ml-[50%] flex-grow">

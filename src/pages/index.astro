<!-- Astro compile désormais ce script en module JS autonome déporté. C'est 100% compatible CSP ("self"). -->
<script>
  // 1. Définition des types et interfaces
  interface Lexicon {
    aventure: string[];
    plages: string[];
    culture: string[];
  }
  interface ProfilLexicon {
    couple: string[];
    famille: string[];
    solo: string[];
    amis: string[];
  }
  interface Lexicons {
    type: Lexicon;
    profil: ProfilLexicon;
  }

  // 2. Définition des constantes et fonctions utilitaires au niveau GLOBAL du module de script
  // Résout définitivement TOUTES les erreurs de portée "Cannot find name" de TypeScript et les race conditions [1.2.3, 2.1]

  const romanNumerals = ["", "I", "II", "III", "IV", "V", "VI"];

  // LEXIQUE AUTOMATIQUE DE CLASSIFICATION DES CARDS
  const lexicons: Lexicons = {
    type: {
      aventure: ['trek', 'randonnée', 'randonnees', 'sentier', 'sentiers', 'montagne', 'montagnes', 'col', 'sommet', 'sommets', 'volcan', 'cirque', 'hiking', 'ascension', 'aiguilles', 'bavella', 'bergeries', 'villages'],
      plages: ['plage', 'plages', 'lagon', 'lagons', 'snorkeling', 'sable', 'côte', 'côtes', 'riviera', 'baignade', 'turquoise', 'crique', 'criques', 'eau', 'ocean', 'vagues', 'surf', 'ksamil', 'côtières', 'mer'],
      culture: ['architecture', 'musée', 'musées', 'patrimoine', 'historique', 'ville', 'villes', 'capitale', 'temple', 'temples', 'gratte-ciel', 'jazz', 'galerie', 'galeries', 'historique', 'chicago', 'bordeaux', 'tokyo', 'moscou', 'splendeurs', 'architecturales', 'cathédrales', 'métros', 'kremlin', 'shibuya', 'shinjuku', 'sanctuaires']
    },
    profil: {
      couple: ['romantique', 'intime', 'escapade', 'escapades', 'duo', 'coucher', 'couchers', 'road-trip', 'douceur', 'bergeries', 'intimes', 'confidents', 'lune', 'vignobles', 'vignes', 'charme'],
      famille: ['famille', 'familles', 'enfant', 'enfants', 'kids', 'accessible', 'baignade sécurisée', 'calme', 'parcs', 'parc', ' road-trip'],
      solo: ['solo', 'sac', 'dos', 'liberté', 'immersion', 'vibrante', 'secrets', 'historique', 'road-trip', 'découvrir'],
      amis: ['amis', 'groupe', 'club', 'festif', 'convivial', 'vagues', 'surf', 'jazz', 'bars', 'session', 'sessions', 'vignobles', 'road-trip']
    }
  };

  function getFavorites(): string[] {
    try {
      const stored = localStorage.getItem('the_odyssey_favorites');
      if (!stored) return [];
      
      const parsed = JSON.parse(stored);
      if (!Array.isArray(parsed)) {
        throw new Error('Données corrompues');
      }
      
      const slugRegex = /^[a-z0-9\-]+$/;
      const isValid = parsed.every(item => typeof item === 'string' && slugRegex.test(item));
      
      if (!isValid) {
        throw new Error('Slugs invalides detectés');
      }
      
      return parsed;
    } catch (e) {
      try {
        localStorage.removeItem('the_odyssey_favorites');
      } catch (err) {}
      return [];
    }
  }

  function sanitizeSearchInput(input: string): string {
    if (typeof input !== 'string') return '';
    
    let cleaned = input.slice(0, 100).replace(/<[^>]*>/g, '');
    
    const escapeMap: Record<string, string> = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#x27;',
      "/": '&#x2F;',
      '`': '&#x60;'
    };
    cleaned = cleaned.replace(/[&<>"'/`]/g, (match) => escapeMap[match]);

    const sqlRegex = /\b(union|select|insert|delete|update|drop|alter|where|and|or|having|truncate)\b/gi;
    cleaned = cleaned.replace(sqlRegex, '');
    
    return cleaned.trim();
  }

  function debounce(func: Function, delay: number) {
    let timeoutId: any;
    return (...args: any[]) => {
      clearTimeout(timeoutId);
      timeoutId = setTimeout(() => {
        func.apply(null, args);
      }, delay);
    };
  }

  // 3. DOMContentLoaded pour la liaison stricte et différée des éléments réactifs [2.1]
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('destination-search') as HTMLInputElement | null;
    const compactSelect = document.getElementById('compact-filter') as HTMLSelectElement | null;
    const needle = document.getElementById('compass-needle') as HTMLElement | null;
    const pageDisplay = document.getElementById('page-display') as HTMLElement | null;
    const prevCompass = document.getElementById('prev-compass') as HTMLButtonElement | null;
    const nextCompass = document.getElementById('next-compass') as HTMLButtonElement | null;
    const cards = document.querySelectorAll('.guide-card') as NodeListOf<HTMLElement>;
    const favBtnMenu = document.getElementById('favorites-menu-btn') as HTMLButtonElement | null;

    // NOUVEAUX ÉLÉMENTS DE FILTRAGE
    const typeButtons = document.querySelectorAll('.filter-btn-type') as NodeListOf<HTMLButtonElement>;
    const profilButtons = document.querySelectorAll('.filter-btn-profil') as NodeListOf<HTMLButtonElement>;
    const resultsCountEl = document.getElementById('results-count') as HTMLElement | null;

    // LECTURE DU CONTEXTE DE RECHERCHE DEPUIS L'URL
    const urlParams = new URLSearchParams(window.location.search);
    let currentFilterType = urlParams.get('type') || 'all';
    let currentFilterProfil = urlParams.get('profil') || 'all';

    let currentFilter = 'all';
    let searchQuery = '';
    let currentPage = 1;
    let cardsPerPage = 6; 
    let visibleCards: HTMLElement[] = [];

    // SCAN & ATTRIBUTION DYNAMIQUE DES ATTRIBUTS DATA-TYPE & DATA-PROFIL
    function autoAttributeCards() {
      cards.forEach(card => {
        const titleEl = card.querySelector('h2');
        const descEl = card.querySelector('p');
        const titleText = titleEl ? titleEl.innerText.toLowerCase() : '';
        const descText = descEl ? descEl.innerText.toLowerCase() : '';
        const fullText = `${titleText} ${descText}`;

        // Attribution des ambiances (type)
        const matchedTypes: string[] = [];
        (Object.entries(lexicons.type) as Array<[string, string[]]>).forEach(([type, keywords]) => {
          if (keywords.some((kw: string) => fullText.includes(kw))) {
            matchedTypes.push(type);
          }
        });
        
        // Ajustements exceptionnels pour classification riche
        const cardId = card.dataset.id;
        if (cardId === 'corse' || cardId === 'albanie') {
          if (!matchedTypes.includes('aventure')) matchedTypes.push('aventure');
          if (!matchedTypes.includes('plages')) matchedTypes.push('plages');
        }
        if (matchedTypes.length === 0) matchedTypes.push('aventure');
        card.setAttribute('data-type', matchedTypes.slice(0, 2).join(' '));

        // Attribution des profils voyageurs
        const matchedProfils: string[] = [];
        (Object.entries(lexicons.profil) as Array<[string, string[]]>).forEach(([profil, keywords]) => {
          if (keywords.some((kw: string) => fullText.includes(kw))) {
            matchedProfils.push(profil);
          }
        });
        if (matchedProfils.length === 0) matchedProfils.push('couple');
        card.setAttribute('data-profil', matchedProfils.join(' '));
      });
    }

    // MISE À JOUR VISUELLE DE L'ACTIVE DES BOUTONS DE FILTRE (Ardoise & Ambré)
    function updateFilterUI() {
      // Ambiance active : #2C3E50
      typeButtons.forEach(btn => {
        const filterVal = btn.getAttribute('data-type-filter');
        if (filterVal === currentFilterType) {
          btn.className = "filter-btn-type px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer bg-[#2C3E50] text-white font-bold shadow-sm scale-102";
        } else {
          btn.className = "filter-btn-type px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 bg-transparent";
        }
      });

      // Profil active : #C8813A
      profilButtons.forEach(btn => {
        const filterVal = btn.getAttribute('data-profil-filter');
        if (filterVal === currentFilterProfil) {
          btn.className = "filter-btn-profil px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer bg-[#C8813A] text-white font-bold shadow-sm scale-102";
        } else {
          btn.className = "filter-btn-profil px-3 py-1.5 rounded-full transition-all duration-300 cursor-pointer text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 bg-transparent";
        }
      });
    }

    // SAUVEGARDE DU CONTEXTE DANS L'URL
    function updateURL() {
      const url = new URL(window.location.href);
      if (currentFilterType !== 'all') {
        url.searchParams.set('type', currentFilterType);
      } else {
        url.searchParams.delete('type');
      }
      if (currentFilterProfil !== 'all') {
        url.searchParams.set('profil', currentFilterProfil);
      } else {
        url.searchParams.delete('profil');
      }
      window.history.pushState({}, '', url.toString());
    }

    function toggleFavorite(cardId: string) {
      let favs = getFavorites();
      if (favs.includes(cardId)) {
        favs = favs.filter(id => id !== cardId);
      } else {
        favs.push(cardId);
      }
      try {
        localStorage.setItem('the_odyssey_favorites', JSON.stringify(favs));
      } catch (e) {}
      updateFavStates();
      
      // Mise à jour de la grille uniquement si l'utilisateur est sur la vue active des favoris
      if (currentFilter === 'favorites') {
        updatePagination();
      }
    }

    // GESTION SYNCHRONISÉE DES CŒURS (CARDS + MENU AVEC BORDURE BLANCHE RENFORCÉE)
    function updateFavStates() {
      const favs = getFavorites();
      
      // 1. Cœurs des fiches : Remplissage ambré et contour blanc plus épais au clic
      cards.forEach(card => {
        const cardId = card.dataset.id;
        const btn = card.querySelector('.fav-btn') as HTMLButtonElement | null;
        const svg = btn ? btn.querySelector('svg') as SVGElement | null : null;
        if (btn && svg && cardId) {
          if (favs.includes(cardId)) {
            svg.classList.add('text-amber-500', 'fill-amber-500', 'stroke-white');
            svg.classList.remove('text-white/90');
            svg.setAttribute('stroke-width', '2.5'); // Bordure blanche plus grasse
          } else {
            svg.classList.remove('text-amber-500', 'fill-amber-500', 'stroke-white');
            svg.classList.add('text-white/90');
            svg.setAttribute('stroke-width', '1.5');
          }
        }
      });

      // 2. Cœur principal du menu supérieur avec bordure blanche grasse
      const menuSvg = favBtnMenu ? favBtnMenu.querySelector('.fav-menu-svg') as SVGElement | null : null;
      if (menuSvg) {
        if (favs.length > 0) {
          menuSvg.classList.add('text-amber-500', 'fill-amber-500', 'stroke-white');
          menuSvg.classList.remove('text-white');
          menuSvg.setAttribute('stroke-width', '2.5'); // Bordure blanche plus grasse
        } else {
          menuSvg.classList.remove('text-amber-500', 'fill-amber-500', 'stroke-white');
          menuSvg.classList.add('text-white');
          menuSvg.setAttribute('stroke-width', '1.8'); // Rétablissement de la finesse initiale
        }
      }

      // 3. Point de notification discret
      const dot = document.getElementById('favorites-dot') as HTMLElement | null;
      if (dot) {
        if (favs.length > 0) {
          dot.classList.add('scale-100', 'opacity-100');
          dot.classList.remove('scale-0', 'opacity-0');
        } else {
          dot.classList.add('scale-0', 'opacity-0');
          dot.classList.remove('scale-100', 'opacity-100');
        }
      }
    }

    // RESTAURATION DE L'ÉTAT DE SESSION DEPUIS LA PAGE DESTINATION
    function restoreSessionState() {
      try {
        const savedScroll = sessionStorage.getItem('odyssey_home_scroll');
        const savedFilter = sessionStorage.getItem('odyssey_home_filter');
        const savedType = sessionStorage.getItem('odyssey_home_type');
        const savedProfil = sessionStorage.getItem('odyssey_home_profil');
        const savedSearch = sessionStorage.getItem('odyssey_home_search');

        if (savedFilter) currentFilter = savedFilter;
        if (savedType) currentFilterType = savedType;
        if (savedProfil) currentFilterProfil = savedProfil;
        if (savedSearch) {
          searchQuery = savedSearch;
          if (searchInput) searchInput.value = savedSearch;
        }

        if (compactSelect) {
          compactSelect.value = currentFilter;
        }

        updateFilterUI();
        updatePagination();

        if (savedScroll) {
          setTimeout(() => {
            window.scrollTo({ top: parseInt(savedScroll), behavior: 'smooth' });
            sessionStorage.removeItem('odyssey_home_scroll');
          }, 400);
        }
      } catch (e) {}
    }

    // ENREGISTREMENT DE L'ÉTAT DE SESSION AVANT LA NAVIGATION VERS UNE CARD
    const destLinks = document.querySelectorAll('.dest-link') as NodeListOf<HTMLAnchorElement>;
    destLinks.forEach(link => {
      link.addEventListener('click', () => {
        try {
          sessionStorage.setItem('odyssey_home_scroll', window.scrollY.toString());
          sessionStorage.setItem('odyssey_home_filter', currentFilter);
          sessionStorage.setItem('odyssey_home_type', currentFilterType);
          sessionStorage.setItem('odyssey_home_profil', currentFilterProfil);
          sessionStorage.setItem('odyssey_home_search', searchQuery);
        } catch (e) {}
      });
    });

    // Assigne les clics favoris sur les cartes (Sans rafraîchir la grille globale pour supprimer le sursaut)
    cards.forEach(card => {
      const cardId = card.dataset.id;
      const btn = card.querySelector('.fav-btn') as HTMLButtonElement | null;
      if (btn && cardId) {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          toggleFavorite(cardId);
        });
      }
    });

    // ÉVÈNEMENTS AU CLIC SUR LES FILTRES HORIZONTAUX (AVEC TOGGLE SI RE-CLIC)
    typeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetType = btn.getAttribute('data-type-filter') || 'all';
        if (targetType === currentFilterType) {
          currentFilterType = 'all'; // Re-clic réinitialise
        } else {
          currentFilterType = targetType;
        }
        currentPage = 1;
        updateFilterUI();
        updateURL();
        updatePagination();
      });
    });

    profilButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetProfil = btn.getAttribute('data-profil-filter') || 'all';
        if (targetProfil === currentFilterProfil) {
          currentFilterProfil = 'all'; // Re-clic réinitialise
        } else {
          currentFilterProfil = targetProfil;
        }
        currentPage = 1;
        updateFilterUI();
        updateURL();
        updatePagination();
      });
    });

    // SYNCHRONISATION DU BOUTON RETOUR NAVIGATEUR
    window.addEventListener('popstate', () => {
      const popParams = new URLSearchParams(window.location.search);
      currentFilterType = popParams.get('type') || 'all';
      currentFilterProfil = popParams.get('profil') || 'all';
      updateFilterUI();
      updatePagination();
    });

    function updatePagination() {
      const favs = getFavorites();

      // 1. Calcul de toutes les cards correspondantes à l'intégralité des filtres actifs (Exclusion complète)
      visibleCards = Array.from(cards).filter(card => {
        const continentSlug = card.dataset.continent ? card.dataset.continent.toLowerCase().replace(/[^a-z0-9]/g, '') : '';
        const countrySlug = card.dataset.country ? card.dataset.country.toLowerCase().replace(/[^a-z0-9]/g, '') : '';
        
        let matchesContinent = false;
        if (currentFilter === 'all') {
          matchesContinent = true;
        } else if (currentFilter === 'favorites') {
          matchesContinent = card.dataset.id ? favs.includes(card.dataset.id) : false;
        } else {
          matchesContinent = (continentSlug === currentFilter || countrySlug === currentFilter);
        }

        const matchesSearch = card.dataset.search ? card.dataset.search.includes(searchQuery) : false;

        const cardTypes = (card.getAttribute('data-type') || '').split(' ');
        const cardProfils = (card.getAttribute('data-profil') || '').split(' ');

        const matchesType = (currentFilterType === 'all' || cardTypes.includes(currentFilterType));
        const matchesProfil = (currentFilterProfil === 'all' || cardProfils.includes(currentFilterProfil));

        return matchesContinent && matchesSearch && matchesType && matchesProfil;
      });

      // Mise à jour du compteur réel de destinations
      if (resultsCountEl) {
        resultsCountEl.innerText = visibleCards.length.toString();
      }

      // 2. Calcul du nombre de pages basées sur les cartes filtrées uniquement
      const totalPages = Math.ceil(visibleCards.length / cardsPerPage) || 1;
      if (currentPage > totalPages) currentPage = totalPages;

      // 3. Affichage en une seule passe sans écroulement (Anti-sursaut complet)
      const start = (currentPage - 1) * cardsPerPage;
      const pageCards = visibleCards.slice(start, start + cardsPerPage);

      cards.forEach(card => {
        const shouldShow = pageCards.includes(card);
        if (shouldShow) {
          if (card.style.display !== 'flex') {
            card.style.display = 'flex';
            void card.offsetHeight; 
          }
          card.style.opacity = '1';
          card.style.transform = 'scale(1)';
          card.style.pointerEvents = 'auto';
        } else {
          card.style.display = 'none';
          card.style.opacity = '0';
          card.style.transform = 'scale(0.95)';
          card.style.pointerEvents = 'none';
        }
      });

      const grid = document.getElementById('guides-grid') as HTMLElement | null;
      let emptyMessage = document.getElementById('empty-favorites-message') as HTMLElement | null;
      if (visibleCards.length === 0) {
        if (!emptyMessage && grid) {
          emptyMessage = document.createElement('div');
          emptyMessage.id = 'empty-favorites-message';
          emptyMessage.className = 'col-span-full py-16 text-center text-neutral-500 font-mono text-[11px] uppercase tracking-wider bg-white rounded-2xl border border-neutral-200/40 p-8 shadow-2xs';
          emptyMessage.innerHTML = `<span class="block text-2xl mb-3">🔍</span> Aucun itinéraire ne correspond à ces filtres. Essayez d'autres ambiances ou profils voyageurs.`;
          grid.appendChild(emptyMessage);
        } else if (emptyMessage) {
          emptyMessage.style.display = 'block';
        }
      } else if (emptyMessage) {
        emptyMessage.style.display = 'none';
      }

      const roman = romanNumerals[currentPage] || currentPage;
      if(pageDisplay) pageDisplay.innerText = `THE ODYSSEY // PAGE ${roman}`;

      if(totalPages === 1) {
        if (prevCompass) { prevCompass.style.opacity = '0.25'; prevCompass.style.pointerEvents = 'none'; }
        if (nextCompass) { nextCompass.style.opacity = '0.25'; nextCompass.style.pointerEvents = 'none'; }
        if (needle) needle.style.transform = 'rotate(0deg)';
      } else {
        if (prevCompass) {
          prevCompass.style.opacity = currentPage === 1 ? '0.25' : '1';
          prevCompass.style.pointerEvents = currentPage === 1 ? 'none' : 'auto';
        }
        if (nextCompass) {
          nextCompass.style.opacity = currentPage === totalPages ? '0.25' : '1';
          nextCompass.style.pointerEvents = currentPage === totalPages ? 'none' : 'auto';
        }
      }
    }

    // CLIC MENU SUPÉRIEUR FAVORIS
    if (favBtnMenu) {
      favBtnMenu.addEventListener('click', (e) => {
        e.preventDefault();
        currentFilter = 'favorites';
        if (compactSelect) compactSelect.value = 'favorites';
        currentPage = 1;
        updatePagination();
        document.getElementById('destinations')?.scrollIntoView({ behavior: 'smooth' });
      });
    }

    // GESTION COMPASS INTERACTIVE WEST / EAST
    if(prevCompass && nextCompass && needle) {
      prevCompass.addEventListener('mouseenter', () => { 
        if(currentPage > 1) {
          needle.style.transform = 'rotate(-30deg) scale(1.08)'; 
          needle.classList.remove('text-neutral-800');
          needle.classList.add('text-amber-600');
        }
      });
      prevCompass.addEventListener('mouseleave', () => { 
        needle.style.transform = 'rotate(0deg) scale(1)'; 
        needle.classList.add('text-neutral-800');
        needle.classList.remove('text-amber-600');
      });
      
      nextCompass.addEventListener('mouseenter', () => { 
        if(currentPage < Math.ceil(visibleCards.length / cardsPerPage)) {
          needle.style.transform = 'rotate(30deg) scale(1.08)'; 
          needle.classList.remove('text-neutral-800');
          needle.classList.add('text-amber-600');
        }
      });
      nextCompass.addEventListener('mouseleave', () => { 
        needle.style.transform = 'rotate(0deg) scale(1)'; 
        needle.classList.add('text-neutral-800');
        needle.classList.remove('text-amber-600');
      });
      
      prevCompass.addEventListener('click', () => { 
        if (currentPage > 1) { 
          currentPage--; 
          updatePagination(); 
          document.getElementById('destinations')?.scrollIntoView({ behavior: 'smooth' });
          needle.style.transform = 'rotate(-60deg) scale(1.08)'; 
          setTimeout(() => needle.style.transform = 'rotate(0deg) scale(1)', 250); 
        } 
      });
      nextCompass.addEventListener('click', () => { 
        if (currentPage < Math.ceil(visibleCards.length / cardsPerPage)) { 
          currentPage++; 
          updatePagination(); 
          document.getElementById('destinations')?.scrollIntoView({ behavior: 'smooth' });
          needle.style.transform = 'rotate(60deg) scale(1.08)'; 
          setTimeout(() => needle.style.transform = 'rotate(0deg) scale(1)', 250); 
        } 
      });
    }

    // FILTRE DEPUIS LE FOOTER
    const footerContinentLinks = document.querySelectorAll('[data-continent-trigger]') as NodeListOf<HTMLElement>;
    footerContinentLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const continentValue = link.getAttribute('data-continent-trigger');
        if (continentValue) {
          currentFilter = continentValue;
          if (compactSelect) {
            compactSelect.value = continentValue;
          }
          currentPage = 1;
          updatePagination();
        }
      });
    });

    // ÉCOUTE ET SÉCURISATION DU CHAMP DE RECHERCHE (Sanitisation + Debounce 300ms)
    if (searchInput) {
      searchInput.addEventListener('input', debounce((e: Event) => {
        const target = e.target as HTMLInputElement | null;
        if (target) {
          searchQuery = sanitizeSearchInput(target.value);
          currentPage = 1;
          updatePagination();
        }
      }, 300));
    }

    if(compactSelect) {
      compactSelect.addEventListener('change', (e) => { 
        const target = e.target as HTMLSelectElement | null;
        if (target) {
          currentFilter = target.value; 
          currentPage = 1; 
          updatePagination(); 
        }
      });
    }

    // Initialisation
    const items = new Set<string>();
    cards.forEach(card => {
      if(card.dataset.continent) items.add(card.dataset.continent);
    });

    let selectHTML = `<option value="all">Explorer le globe (Tous)</option>`;
    selectHTML += `<option value="favorites">Mes Favoris ❤️</option>`; 
    items.forEach(item => {
      const slug = item.toLowerCase().replace(/[^a-z0-9]/g, '');
      selectHTML += `<option value="${slug}">${item}</option>`;
    });
    if(compactSelect) compactSelect.innerHTML = selectHTML;

    // Initialisation globale, auto-classification et restauration éventuelle d'état
    autoAttributeCards();
    updateFilterUI();
    updateFavStates();
    restoreSessionState();

    const images = document.querySelectorAll('.slide-img') as NodeListOf<HTMLElement>;
    let currentIndex = 0;
    if(images.length > 0) {
      setInterval(() => {
        images[currentIndex].style.opacity = '0';
        currentIndex = (currentIndex + 1) % images.length;
        images[currentIndex].style.opacity = '0.6';
      }, 3000);
    }
  });
</script>
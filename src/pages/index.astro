---
import Layout from '../layouts/Layout.astro';
---

<Layout title="THE ODYSSEY | Slow Travel Magazine & Guides Complets">
  
  <!-- HERO SLIDER PLEIN ÉCRAN TOTAL (H-SCREEN STYLE BOKO STUDIO) -->
  <section class="relative h-screen w-full bg-neutral-950 flex items-center justify-center text-center px-4 sm:px-6 overflow-hidden">
    <div class="absolute inset-0 z-0 pointer-events-none select-none">
      <img 
        src="/images/drone/drone-albania-5.JPG" 
        alt="The Odyssey Slide 1" 
        class="slide-img absolute inset-0 w-full h-full object-cover opacity-65 transition-opacity duration-1000 ease-in-out" 
      />
      <img 
        src="/images/drone/drone-albania-1.JPG" 
        alt="The Odyssey Slide 2" 
        class="slide-img absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out" 
      />
      <img 
        src="/images/drone/drone-albania-2.JPG" 
        alt="The Odyssey Slide 3" 
        class="slide-img absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out" 
      />
      
      <!-- MASQUE NOIR TRANSITORY COMPATIBLE CHROME/SAFARI -->
      <div class="absolute inset-0 bg-gradient-to-b from-neutral-950/20 via-transparent to-neutral-950/30 z-10"></div>
      
      <!-- FADE DE TRANSITION BASSE COMPATIBLE TOUS MOTEURS -->
      <div class="absolute bottom-0 left-0 right-0 h-[25vh] bg-gradient-to-b from-transparent to-[#FAF7F2] z-10"></div>
    </div>

    <!-- TEXTE INTEGRÉ AVEC UNITÉS ADAPTATIVES EM/REM -->
    <div class="relative z-20 w-full max-w-4xl mx-auto text-white space-y-4 px-2">
      <span class="text-[10px] font-mono tracking-[0.5em] uppercase text-neutral-200 block drop-shadow-xs">Slow Travel Magazine</span>
      <h1 class="text-3xl sm:text-5xl md:text-7xl font-serif font-light tracking-tight leading-[1.2] drop-shadow-md">
        Prendre le temps de<br/><span class="italic font-normal text-neutral-100">découvrir le monde.</span>
      </h1>
      <p class="text-neutral-200 max-w-md mx-auto text-[9px] sm:text-[10px] font-mono tracking-widest uppercase pt-2 sm:pt-4 drop-shadow-xs">
        Guides complets de 1 à 2 semaines pour explorateurs libres
      </p>
    </div>
  </section>
  <!-- SECTION DESTINATIONS SÉCURISÉE CONTRE LE ZOOM -->
  <section id="destinations" class="w-full max-w-[1600px] mx-auto px-4 sm:px-8 md:px-12 py-16 sm:py-20 border-t border-neutral-200/60 scroll-mt-20 overflow-hidden">
    
    <!-- EN-TÊTE ULTRA-RESPONSIVE COMPATIBLE SAFARI ET CHROME MOBILE -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-12 border-b border-neutral-200/40 pb-8">
      
      <!-- TITRE DE SECTION AVEC ICONE SIGNATURE BOUSSOLE INTERACTIVE -->
      <div class="flex items-center space-x-3 group/section-title cursor-default text-center sm:text-left">
        <div class="w-4 h-4 text-amber-600 group-hover/section-title:rotate-45 group-hover/section-title:text-amber-500 transition-all duration-500 ease-out shrink-0">
          <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="2"></path>
            <path fill="currentColor" d="M12 7l1.5 3.5L12 12l-1.5-1.5zM12 17l1.5-3.5L12 12l-1.5 1.5z"></path>
          </svg>
        </div>
        <span class="text-[10px] font-mono tracking-[0.4em] uppercase text-neutral-400 group-hover/section-title:text-amber-700 transition-colors duration-300">
          Nos Itinéraires au Long Cours
        </span>
      </div>

      <!-- FILTRES RESPONSIVES ALIGNÉS SANS CHEVAUCHEMENT -->
      <div class="flex flex-col xs:flex-row items-center gap-3 w-full sm:w-auto justify-end">
        <!-- Input Recherche -->
        <div class="relative w-full xs:w-48 sm:w-56">
          <input 
            type="text" 
            id="destination-search" 
            placeholder="Rechercher..." 
            class="w-full bg-[#FFFFFF] border border-neutral-200/80 px-3 py-2 pl-8 text-[11px] font-mono uppercase tracking-wider text-neutral-800 placeholder-neutral-400 focus:outline-hidden focus:border-amber-600 rounded-xs transition-colors shadow-2xs"
          />
          <span class="absolute left-2.5 top-2.5 text-neutral-400 text-[10px]">🔍</span>
        </div>
        
        <!-- Menu Déroulant Compact -->
        <div class="relative w-full xs:w-auto">
          <select 
            id="compact-filter" 
            class="w-full xs:w-auto bg-[#FFFFFF] border border-neutral-200/80 px-4 py-2 pr-8 text-[11px] font-mono uppercase tracking-widest text-neutral-700 focus:outline-hidden focus:border-amber-600 rounded-xs transition-colors shadow-2xs appearance-none cursor-pointer"
          >
          </select>
          <span class="absolute right-3 top-3 text-[8px] text-neutral-400 pointer-events-none">▼</span>
        </div>
      </div>
    </div>
    
    <!-- CONTENEUR GRILLE BLINDÉ -->
    <div id="guides-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12 sm:gap-x-8 sm:gap-y-16 transition-all duration-500">
      <!-- CARD 1 : ALBANIE -->
      <article class="guide-card group flex flex-col justify-between h-full bg-[#FFFFFF] border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow w-full mx-auto" data-continent="Europe" data-country="Albanie" data-search="europe balkans albanie riviera parcs tirana ksamil">
        <div class="w-full aspect-[16/10] overflow-hidden bg-neutral-100 relative">
          <span class="absolute top-3 left-3 bg-neutral-950 text-white text-[7px] font-mono uppercase tracking-[0.1em] px-2 py-0.5 z-10">1 Semaine</span>
          <img src="/images/drone/drone-albania-5.JPG" alt="Guide Itinéraire Albanie" class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-1000 ease-out" />
        </div>
        <div class="p-5 sm:p-6 flex-grow flex flex-col justify-between space-y-4">
          <div class="space-y-2">
            <span class="text-[8px] font-mono text-neutral-400 uppercase tracking-widest block font-medium">Europe // Balkans // Albanie</span>
            <h2 class="text-base sm:text-lg font-serif font-light text-neutral-900 leading-snug group-hover:text-amber-800 transition-colors">Albanie : Riviera & Parcs</h2>
            <p class="text-[11px] sm:text-xs text-neutral-500 font-light leading-relaxed">De Tirana aux plages sauvages de Ksamil. Un road-trip équilibré d'une semaine complète entre villages de pierre et criques cachées.</p>
          </div>
          <div class="pt-4 border-t border-neutral-100 space-y-2 text-[10px] font-mono">
            <a href="https://booking.com" target="_blank" rel="noopener noreferrer" class="block text-amber-700 hover:underline font-bold">🏢 Logements conseillés</a>
            <a href="https://saily.com" target="_blank" rel="noopener noreferrer" class="block text-neutral-400 hover:text-amber-700 transition-colors">📱 Activer son eSIM Albanie (-5%)</a>
            <div class="pt-2 text-neutral-900 font-medium uppercase tracking-widest border-b border-neutral-900 w-max pb-0.5 group-hover:text-amber-700 group-hover:border-amber-700 transition-colors cursor-pointer">Découvrir →</div>
          </div>
        </div>
      </article>

      <!-- CARD 2 : LA CORSE -->
      <article class="guide-card group flex flex-col justify-between h-full bg-[#FFFFFF] border border-neutral-200/40 overflow-hidden shadow-2xs hover:shadow-xs transition-shadow w-full mx-auto" data-continent="Europe" data-country="France" data-search="europe france corse ile beaute piana bonifacio bavella">

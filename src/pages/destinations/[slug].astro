---
import Layout from '../../layouts/Layout.astro';
import destinationsData from '../../data/destinations.json';

// Configuration du routage dynamique Astro
export async function getStaticPaths() {
  return destinationsData.map((dest) => ({
    params: { slug: dest.slug },
    props: { dest },
  }));
}

const { dest } = Astro.props;

// 1. SÉCURISATION & EN-TÊTE [5]
const slugRegex = /^[a-z0-9\-]+$/;
if (!slugRegex.test(dest.slug)) {
  return Astro.redirect('/404');
}

const allowedDomains = ["booking.com", "nomadesim.com", "chapkadirect.fr"];
const validateLink = (urlStr: string) => {
  try {
    const url = new URL(urlStr);
    return allowedDomains.some(domain => url.hostname === domain || url.hostname.endsWith('.' + domain));
  } catch(e) {
    return false;
  }
};

const bookingLink = validateLink(dest.liens.booking) ? dest.liens.booking : "https://booking.com";
const esimLink = validateLink(dest.liens.esim) ? dest.liens.esim : "https://www.nomadesim.com/";

const country = dest.geo.split(' // ').pop() || 'Exploration';
const continent = dest.geo.split(' // ')[0] || 'Continent';

// Séparation du titre de la carte en deux parties pour l'accentuation ambrée éditoriale (sans double point)
const titleParts = dest.titre.split(':');
const titleMain = titleParts[0].trim();
const titleSub = titleParts[1] ? titleParts[1].trim() : '';

// Séparation de la géo-localisation pour styliser le pays en orange ambré
const geoPartsList = dest.geo.split(' // ');

const ratingStars = "★".repeat(Math.round(dest.note)) + "☆".repeat(5 - Math.round(dest.note));

const similarDestinations = destinationsData
  .filter((d) => d.slug !== dest.slug && (d.type.some(t => dest.type.includes(t)) || d.profil.some(p => dest.profil.includes(p))))
  .slice(0, 3);
---

<Layout title={`${dest.titre} | The Odyssey`}>
  
  <div class="dest-page-wrapper">
    
    <!-- HERO PLEINE LARGEUR — IMAGE PURE ET TEXTE CENTRÉ -->
    <section class="hero select-none relative h-[520px]">
      <img src={dest.image} alt={dest.titre} class="absolute inset-0 w-full h-full object-cover opacity-90 z-0" />
      <div class="hero-overlay z-10"></div>
      
      <!-- Bouton de retour discret et élégant positionné sous l'en-tête de navigation -->
      <div id="back-to-home-btn" class="hero-back z-30 group/back">
        ← Retour aux destinations
        <span class="absolute bottom-1 left-3 w-0 h-[3px] bg-amber-500/35 transition-all duration-300 group-hover/back:w-[82%] -z-10 rounded-xs"></span>
      </div>
      
      <!-- Cœur favori interactif synchronisé, rehaussé en z-30 pour être cliquable en premier plan -->
      <button id="dest-fav-btn" data-id={dest.slug} class="hero-fav z-30" aria-label="Ajouter aux favoris">
        <svg viewBox="0 0 24 24" class="transition-all duration-300"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>
      
      <div class="hero-content z-20">
        <!-- Localisation géo stylisée (le pays ressort en orange ambré fluide) -->
        <span class="hero-geo uppercase">
          {geoPartsList.map((part, idx) => (
            <>
              {idx > 0 && <span class="geo-sep"> // </span>}
              <span class={idx === geoPartsList.length - 1 ? "geo-country" : "geo-parent"}>{part}</span>
            </>
          ))}
        </span>

        <!-- Titre principal : Avec l'accentuation de thème sur une nouvelle ligne en italique ambré fluide -->
        <h1 class="hero-title">
          {titleMain}
          {titleSub && <span class="hero-title-accent block mt-1.5 sm:mt-2">{titleSub}</span>}
        </h1>

        <!-- Sous-titre automatique en blanc doux pour une visibilité irréprochable -->
        <h2 class="hero-subtitle">{dest.sous_titre}</h2>
        
        <div class="hero-tags">
          {dest.type.map((t) => (
            <span class="hero-tag">
              {t === 'aventure' ? '🥾 Aventure' : t === 'plages' ? '🏖️ Plages' : '🏛️ Culture'}
            </span>
          ))}
          {dest.profil.map((p) => (
            <span class="hero-tag">
              {p === 'couple' ? '👫 Couple' : p === 'famille' ? '👨‍👩‍👧 Famille' : p === 'solo' ? '🧍 Solo' : '👥 Amis'}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- BLOC AUTEUR & STATS AVEC ÉTOILES À GAUCHE ET STATS À DROITE -->
    <div class="author-stats border-b border-[#E0D9D0]">
      <!-- Gauche : Auteur & Avis / Étoiles (L'année a disparu) -->
      <div class="author-part select-none">
        <div class="author-avatar">{dest.auteur.initiale}</div>
        <div>
          <div class="author-name">Récit de {dest.auteur.nom}</div>
          <div class="rating-inline">
            <span class="stars">{ratingStars}</span>
            <span class="rating-count">{dest.note.toFixed(1)} · {dest.nb_avis} avis</span>
          </div>
        </div>
      </div>
      
      <!-- Droite : Stats du séjour -->
      <div class="stats-right select-none">
        <div class="stat-inline"><span class="text-base block mb-0.5">📅</span><div class="stat-inline-val font-serif font-bold">{dest.stats.duree}</div><div class="stat-inline-lbl">Notre séjour</div></div>
        <div class="sep-v"></div>
        <div class="stat-inline"><span class="text-base block mb-0.5">🗺️</span><div class="stat-inline-val font-serif font-bold">{dest.stats.etapes}</div><div class="stat-inline-lbl">Itinéraire</div></div>
        <div class="sep-v"></div>
        <div class="stat-inline"><span class="text-base block mb-0.5">💶</span><div class="stat-inline-val font-serif font-bold">{dest.stats.budget}</div><div class="stat-inline-lbl">Budget / pers.</div></div>
        <div class="sep-v"></div>
        <div class="stat-inline"><span class="text-base block mb-0.5">🌤️</span><div class="stat-inline-val font-serif font-bold">{dest.stats.periode}</div><div class="stat-inline-lbl">Meilleure période</div></div>
      </div>
    </div>

    <!-- AGENCEMENT DE LA PAGE -->
    <div class="page max-w-[1600px] mx-auto px-6 sm:px-8 md:px-12 relative overflow-visible">
      
      <!-- TRAJET DU VAN EN SVG MINIMALISTE POINTILLÉ (STICKY À DROITE) -->
      <div class="trail-right hidden lg:block">
        <div class="trail-sticky">

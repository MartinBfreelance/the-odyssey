                              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-amber-500"></span>
                            </span>
                            {p.promo.code === 'LIEN DIRECT' ? 'Remise appliquée automatiquement via notre lien' : `Code : ${p.promo.code} (${p.promo.reduction})`}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                  
                  <div class="shrink-0 self-start md:self-auto select-none">
                    <a href={resolvedUrl} target="_blank" rel="noopener noreferrer" class="partner-cta block text-center select-none whitespace-nowrap">
                      {p.button_text} →

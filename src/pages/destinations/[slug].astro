              </div>
            </div>
            <div class="pratique-item">
              <div class="pratique-icon">🚗</div>
              <div>
                <div class="pratique-label">Se déplacer</div>
                <div class="pratique-text">{deplacerPratique}</div>
              </div>
            </div>
            <!-- Correction du bug de l'icône de monnaie -->
            <div class="pratique-item">
              <div class="pratique-icon">💶</div>

---
import Layout from '../../layouts/Layout.astro';
import destinationsData from '../../data/destinations.json';
import partners from '../../data/partners.json';

export async function getStaticPaths() {
  return destinationsData.map((dest) => ({
    params: { slug: dest.slug },
    props: { dest },
  }));
}

const { dest } = Astro.props;

const slugRegex = /^[a-z0-9\-]+$/;
if (!slugRegex.test(dest.slug)) {
  return Astro.redirect('/404');
}

// Typage sécurisé pour TypeScript en mode strict
const getPartnerUrl = (partnerId: string, defaultUrl: string) => {
  const liens = dest.liens as Record<string, string> | undefined;
  return liens && liens[partnerId] ? liens[partnerId] : defaultUrl;
};

const country = dest.geo.split(' // ').pop() || 'Exploration';
const titleParts = dest.titre.split(':');
const titleMain = titleParts[0].trim();
const titleSub = titleParts[1] ? titleParts[1].trim() : '';
const geoPartsList = dest.geo.split(' // ');
const ratingStars = "★".repeat(Math.round(dest.note)) + "☆".repeat(5 - Math.round(dest.note));

const similarDestinations = destinationsData
  .filter((d) => d.slug !== dest.slug && (d.type.some(t => dest.type.includes(t)) || d.profil.some(p => dest.profil.includes(p))))
  .slice(0, 3);

// ANALYSE AUTO INFOS PRATIQUES
const bodyToScan = `${dest.titre} ${dest.sous_titre} ${dest.stats.duree || ''} ${dest.stats.etapes || ''} ${dest.stats.budget || ''}`.toLowerCase();
let autoDuree = dest.stats.duree;
const dureeMatch = /(\d+)\s*(jours|jours\b|j\b)/g.exec(bodyToScan);
if (dureeMatch) autoDuree = `${dureeMatch[1]} jours`;
else if (bodyToScan.includes("semaine")) autoDuree = "7 jours";

let autoEtapes = dest.stats.etapes;
const etapesMatch = /(\d+)\s*(étapes|étape|haltes|arrêts)/g.exec(bodyToScan);
if (etapesMatch) autoEtapes = `${etapesMatch[1]} étapes`;

let autoBudget = dest.stats.budget;
const budgetMatch = /(~?\s*\d+[\s\d]*)\s*(€|euros)/g.exec(bodyToScan);
if (budgetMatch) {
  let extractedVal = budgetMatch[1].trim();
  if (!extractedVal.startsWith('~') && (bodyToScan.includes('environ') || bodyToScan.includes('budget moyen'))) {
    extractedVal = `~${extractedVal}`;
  }
  autoBudget = `${extractedVal}€`.replace(/\s+/g, ' ');
}

let autoPeriode = dest.stats.periode;
const climateDatabase: Record<string, string> = {
  'albanie': 'Mai – Sept.', 'corse': 'Mai – Oct.', 'chicago': 'Mai – Sept.',
  'usa': 'Mai – Sept.', 'france': 'Mai – Oct.', 'italie': 'Avril – Oct.',
  'maroc': 'Oct. – Avril', 'espagne': 'Mai – Oct.', 'russie': 'Mai – Sept.', 'islande': 'Juin – Août'
};
if (climateDatabase[country.toLowerCase().trim()]) {
  autoPeriode = climateDatabase[country.toLowerCase().trim()];
}

// Lecture des infos pratiques directement du JSON (avec repli sur les valeurs par défaut globales)
const docPratique = dest.doc_pratique || "Carte d'identité ou passeport en cours de validité (UE). Aucun visa requis.";
const volPratique = dest.vol_pratique || "Vols directs ou avec escale depuis la Belgique.";
const deplacerPratique = dest.deplacement_pratique || "Location de voiture recommandée sur place.";
const monnaiePratique = dest.monnaie_pratique || "Euro (€) conseillé.";
---

<Layout title={`${dest.titre} | The Odyssey`}>
  <div class="dest-page-wrapper">
    
    <!-- HERO HEADER -->
    <section class="hero select-none relative h-[560px]">
      <img src={dest.image} alt={dest.titre} class="absolute inset-0 w-full h-full object-cover opacity-90 z-0" />
      <div class="hero-overlay z-10"></div>
      
      <a href="/#destinations" id="back-to-home-btn" class="hero-back z-30">← Retour aux destinations</a>
      
      <button id="dest-fav-btn" data-id={dest.slug} class="hero-fav z-30" aria-label="Ajouter aux favoris">
        <svg viewBox="0 0 24 24" class="transition-all duration-300"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>
      
      <div class="hero-content z-20">
        <span class="hero-geo uppercase">
          {geoPartsList.map((part, idx) => (
            <>
              {idx > 0 && <span class="geo-sep"> // </span>}
              <span class={idx === geoPartsList.length - 1 ? "geo-country" : "geo-parent"}>{part}</span>
            </>
          ))}
        </span>
        <h1 class="hero-title">
          {titleMain}
          {titleSub && <span class="hero-title-accent block mt-1.5 sm:mt-2">{titleSub}</span>}
        </h1>
        <h2 class="hero-subtitle">{dest.sous_titre}</h2>
        <div class="hero-tags">
          {dest.type.map((t) => <span class="hero-tag">{t === 'aventure' ? '🥾 Aventure' : t === 'plages' ? '🏖️ Plages' : '🏛️ Culture'}</span>)}
          {dest.profil.map((p) => <span class="hero-tag">{p === 'couple' ? '👫 Couple' : p === 'famille' ? '👨‍👩‍👧 Famille' : p === 'solo' ? '🧍 Solo' : '👥 Amis'}</span>)}
        </div>
      </div>
    </section>

    <!-- BARRE DE STATS -->
    <div class="author-stats border-b border-[#E0D9D0]">
      <div class="author-part select-none">
        <div class="author-avatar">{dest.auteur.initiale}</div>
        <div>
          <div class="author-name">Récit de {dest.auteur.nom}</div>
          <div class="rating-inline">
            <span class="stars">{ratingStars}</span>
            <span class="rating-count">{dest.note.toFixed(1)} · {dest.nb_avis} avis</span>
          </div>
        </div>
      </div>
      <div class="stats-right select-none">
        <div class="stat-inline"><span class="text-base block mb-0.5">📅</span><div class="stat-inline-val font-serif font-bold">{autoDuree}</div><div class="stat-inline-lbl">Notre séjour</div></div>
        <div class="sep-v"></div>
        <div class="stat-inline"><span class="text-base block mb-0.5">🗺️</span><div class="stat-inline-val font-serif font-bold">{autoEtapes}</div><div class="stat-inline-lbl">Itinéraire</div></div>
        <div class="sep-v"></div>
        <div class="stat-inline"><span class="text-base block mb-0.5">💶</span><div class="stat-inline-val font-serif font-bold">{autoBudget}</div><div class="stat-inline-lbl">Budget / pers.</div></div>
        <div class="sep-v"></div>
        <div class="stat-inline"><span class="text-base block mb-0.5">🌤️</span><div class="stat-inline-val font-serif font-bold">{autoPeriode}</div><div class="stat-inline-lbl">Période</div></div>
      </div>
    </div>

    <!-- CORPS DE PAGE -->
    <div class="page max-w-[1600px] mx-auto px-6 sm:px-8 md:px-12 relative overflow-visible">
      
      <!-- TRAJET VAN SVG -->
      <div class="trail-right hidden lg:block">
        <div class="trail-sticky">
          <svg width="44" height="520" viewBox="0 0 44 520" xmlns="http://www.w3.org/2000/svg" class="overflow-visible">
            <path id="travel-path" d="M22 50 C34 90, 10 130, 22 170 C34 210, 10 250, 22 290 C34 330, 10 370, 22 410 C34 450, 10 490, 22 520" fill="none" stroke="#D6CFC4" stroke-width="1.5" stroke-dasharray="4 7" stroke-linecap="round"/>
            <circle cx="22" cy="170" r="3.5" fill="#C8813A" opacity="0.6"/><circle cx="22" cy="290" r="3.5" fill="#C8813A" opacity="0.6"/><circle cx="22" cy="410" r="3.5" fill="#C8813A" opacity="0.6"/>
            <g id="scrolling-van" transform="translate(4, 14)">
              <rect x="0" y="12" width="34" height="16" rx="3" fill="#2C3E50"/><rect x="3" y="4" width="24" height="12" rx="2" fill="#2C3E50"/>
              <rect x="5" y="6" width="9" height="7" rx="1" fill="#F5F2ED" opacity="0.55"/><rect x="16" y="6" width="9" height="7" rx="1" fill="#F5F2ED" opacity="0.55"/>
              <rect x="27" y="5" width="5" height="9" rx="1" fill="#C8813A" opacity="0.7"/>
              <circle cx="8" cy="29" r="4.5" fill="#1a2a38"/><circle cx="8" cy="29" r="2" fill="#D6CFC4"/>
              <circle cx="26" cy="29" r="4.5" fill="#1a2a38"/><circle cx="26" cy="29" r="2" fill="#D6CFC4"/>
            </g>
          </svg>
        </div>
      </div>

      <div class="content w-full lg:w-[calc(100%-44px)]">
        
        <!-- COUP DE COEUR -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="relative text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-950 font-bold group-hover/sec-title:text-amber-800 transition-colors duration-300 select-none">
              Notre coup de cœur
              <span class="absolute bottom-0 left-0 w-0 h-[4px] bg-amber-500/15 group-hover/sec-title:w-full transition-all duration-500 ease-out rounded-xs"></span>
            </span>
            <div class="section-line"></div>
          </div>
          <div class="section-title">{dest.coup_de_coeur_titre || "L'île qui résume tout ce qu'on aime dans le voyage"}</div>
          <div class="section-text font-sans">{dest.coup_de_coeur_texte || "On ne s'attendait pas à tomber aussi fort pour cette destination."}</div>
        </div>

        <!-- ITINÉRAIRE -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="relative text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-950 font-bold group-hover/sec-title:text-amber-800 transition-colors duration-300 select-none">
              Notre itinéraire
              <span class="absolute bottom-0 left-0 w-0 h-[4px] bg-amber-500/15 group-hover/sec-title:w-full transition-all duration-500 ease-out rounded-xs"></span>
            </span>
            <div class="section-line"></div>
          </div>

          {dest.etapes_details ? (
            dest.etapes_details.map((etape, idx) => (
              <div class="etape pb-6 border-b border-[#E0D9D0]/60 last:border-b-0 last:pb-0">
                <div class="etape-header flex flex-col md:flex-row md:items-center justify-between gap-5 md:gap-6 w-full">
                  <div class="flex items-start gap-3 flex-grow">
                    <div class="etape-num">{idx + 1}</div>
                    <div class="space-y-3">
                      <div class="etape-title font-serif font-bold text-neutral-900 text-base">{etape.titre}</div>
                      <div class="etape-text font-sans max-w-xl">{etape.texte}</div>
                    </div>
                  </div>
                  <div class="w-full md:w-[550px] shrink-0 aspect-[16/10] overflow-hidden rounded-xl border border-[#E0D9D0] shadow-2xs">
                    <img src={etape.image || dest.image} alt={etape.titre} class="w-full h-full object-cover" />
                  </div>
                </div>
              </div>
            ))
          ) : (
            <div class="etape pb-6">
              <div class="etape-header flex flex-col md:flex-row md:items-center justify-between gap-5 w-full">
                <div class="flex items-start gap-3 flex-grow">
                  <div class="etape-num">1</div>
                  <div class="space-y-3">
                    <div class="etape-title font-serif font-bold text-neutral-900 text-base">Premier contact & immersion locale</div>
                    <div class="etape-text font-sans max-w-xl">Prendre le temps de s'imprégner du climat et d'écouter les bruits locaux.</div>
                  </div>
                </div>
                <div class="w-full md:w-[550px] shrink-0 aspect-[16/10] overflow-hidden rounded-xl border border-[#E0D9D0]">
                  <img src={dest.image} alt="Étape 1" class="w-full h-full object-cover" />
                </div>
              </div>
            </div>
          )}
        </div>

        <!-- BLOC : LA FEUILLE DE ROUTE (Titre principal fusionné et espacement mt-2 corrigé sans sous-titre parasite) -->
        {dest.points_interet && (
          <div class="section text-left">
            <div class="section-header group/sec-title">
              <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                  <circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                  <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
                  <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                  <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
                </svg>
              </div>
              <span class="relative text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-950 font-bold group-hover/sec-title:text-amber-800 transition-colors duration-300 select-none">
                Nos spots clés que vous devez absolument voir
                <span class="absolute bottom-0 left-0 w-0 h-[4px] bg-amber-500/15 group-hover/sec-title:w-full transition-all duration-500 ease-out rounded-xs"></span>
              </span>
              <div class="section-line"></div>
            </div>
            
            <!-- Liste à puces positionnée directement sous l'en-tête avec une marge mt-2 soignée -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-4 mt-2 font-sans text-xs text-neutral-600 font-light leading-relaxed select-text">
              {dest.points_interet.map((point) => {
                const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${point} ${country}`)}`;
                
                return (
                  <div class="flex items-start gap-3">
                    <span class="text-amber-600 text-sm select-none shrink-0 font-bold">✔</span>
                    <div class="flex flex-col sm:flex-row sm:items-center gap-1.5 sm:gap-3 flex-wrap">
                      <span class="text-neutral-800 font-normal">{point}</span>
                      <a 
                        href={mapsUrl} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="inline-flex items-center gap-1 text-[9px] font-mono text-amber-700 hover:text-neutral-900 border-b border-amber-700/20 hover:border-neutral-900 transition-colors uppercase tracking-wider select-none shrink-0"
                        title={`Chercher "${point}" sur Google Maps`}
                      >
                        📍 Localiser
                      </a>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- NOS TROUVAILLES (Logo Boussole & Highlight restaurés) -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="relative text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-950 font-bold group-hover/sec-title:text-amber-800 transition-colors duration-300 select-none">
              Nos trouvailles
              <span class="absolute bottom-0 left-0 w-0 h-[4px] bg-amber-500/15 group-hover/sec-title:w-full transition-all duration-500 ease-out rounded-xs"></span>
            </span>
            <div class="section-line"></div>
          </div>
          <div class="trouvailles-grid font-mono">
            {dest.trouvailles ? (
              dest.trouvailles.map((t) => (
                <div class="trouvaille-card">
                  <div class="trouvaille-icon">{t.icon}</div>
                  <div class="trouvaille-title font-serif font-bold">{t.titre}</div>
                  <div class="trouvaille-text font-sans">{t.texte}</div>
                </div>
              ))
            ) : (
              <div class="trouvaille-card">
                <div class="trouvaille-icon">🍽️</div>
                <div class="trouvaille-title font-serif font-bold">Le bistrot secret</div>
                <div class="trouvaille-text font-sans">Petit resto authentique face à la mer.</div>
              </div>
            )}
          </div>
        </div>

        <!-- INFOS PRATIQUES (Alignement harmonisé et boîtes fines) -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="relative text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-950 font-bold group-hover/sec-title:text-amber-800 transition-colors duration-300 select-none">
              Infos pratiques
              <span class="absolute bottom-0 left-0 w-0 h-[4px] bg-amber-500/15 group-hover/sec-title:w-full transition-all duration-500 ease-out rounded-xs"></span>
            </span>
            <div class="section-line"></div>
          </div>
          <div class="pratique-grid font-sans text-left select-none">
            <!-- Modification de la mention Documents par Documents nécessaires sur demande -->
            <div class="pratique-item"><div class="pratique-icon">🛂</div><div><div class="pratique-label font-bold text-[8px] tracking-wider text-amber-700 uppercase">Documents nécessaires</div><div class="pratique-text text-[10.5px] leading-relaxed text-neutral-600">{docPratique}</div></div></div>
            <div class="pratique-item"><div class="pratique-icon">✈️</div><div><div class="pratique-label font-bold text-[8px] tracking-wider text-amber-700 uppercase">Vol depuis la Belgique</div><div class="pratique-text text-[10.5px] leading-relaxed text-neutral-600">{volPratique}</div></div></div>
            <div class="pratique-item"><div class="pratique-icon">🚗</div><div><div class="pratique-label font-bold text-[8px] tracking-wider text-amber-700 uppercase">Se déplacer</div><div class="pratique-text text-[10.5px] leading-relaxed text-neutral-600">{deplacerPratique}</div></div></div>
            <div class="pratique-item"><div class="pratique-icon">💶</div><div><div class="pratique-label font-bold text-[8px] tracking-wider text-amber-700 uppercase">Monnaie</div><div class="pratique-text text-[10.5px] leading-relaxed text-neutral-600">{monnaiePratique}</div></div></div>
          </div>
        </div>

        <!-- PRÉPARER VOTRE VOYAGE (Serré, sans padding pt-4 parasite, et fiches partenaires minces) -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="relative text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-950 font-bold group-hover/sec-title:text-amber-800 transition-colors duration-300 select-none">
              Préparer votre voyage
              <span class="absolute bottom-0 left-0 w-0 h-[4px] bg-amber-500/15 group-hover/sec-title:w-full transition-all duration-500 ease-out rounded-xs"></span>
            </span>
            <div class="section-line"></div>
          </div>
          
          <!-- Espacement corrigé : pt-0 pour un alignement symétrique parfait -->
          <div class="space-y-3 select-none">
            {partners.filter(p => p.active).map((p) => {
              const resolvedUrl = getPartnerUrl(p.id, p.default_url);
              
              // Automatisation textuelle éditoriale
              let customDesc = p.desc;
              if (p.id === 'booking') {
                customDesc = `Dénichez votre hébergement idéal à ${titleMain} : guesthouses de charme, hôtels confidentiels ou adresses insolites sélectionnés par nos soins.`;
              } else if (p.id === 'nomad') {
                customDesc = `Restez connectés dès votre arrivée à ${titleMain} en activant une eSIM locale. Idéal pour utiliser vos cartes GPS et WhatsApp sans frais d'itinérance.`;
              } else if (p.id === 'chapka') {
                customDesc = `Partez l'esprit serein pour explorer ${country}. Profitez d'une couverture médicale complète, d'une assistance rapatriement et d'une assurance annulation de vol.`;
              } else if (p.id === 'vols') {
                customDesc = `Comparez et réservez les meilleures liaisons aériennes et billets d'avion depuis la Belgique pour rejoindre ${titleMain} au meilleur tarif.`;
              } else if (p.id === 'voiture') {
                customDesc = `Explorez ${titleMain} et ses environs en toute liberté. Louer un véhicule est le moyen idéal pour arpenter notre feuille de route à votre propre rythme.`;

---
import Layout from '../../layouts/Layout.astro';
import destinationsData from '../../data/destinations.json';

// Configuration du routage dynamique Astro
export async function getStaticPaths() {
  return destinationsData.map((dest) => ({
    params: { slug: dest.slug },
    props: { dest },
  }));
}

const { dest } = Astro.props;

// 1. SÉCURISATION & EN-TÊTE [5]
const slugRegex = /^[a-z0-9\-]+$/;
if (!slugRegex.test(dest.slug)) {
  return Astro.redirect('/404');
}

const allowedDomains = ["booking.com", "nomadesim.com", "chapkadirect.fr"];
const validateLink = (urlStr: string) => {
  try {
    const url = new URL(urlStr);
    return allowedDomains.some(domain => url.hostname === domain || url.hostname.endsWith('.' + domain));
  } catch(e) {
    return false;
  }
};

const bookingLink = validateLink(dest.liens.booking) ? dest.liens.booking : "https://booking.com";
const esimLink = validateLink(dest.liens.esim) ? dest.liens.esim : "https://www.nomadesim.com/";

const country = dest.geo.split(' // ').pop() || 'Exploration';
const continent = dest.geo.split(' // ')[0] || 'Continent';

// Séparation du titre de la carte en deux parties pour l'accentuation ambrée éditoriale (sans double point)
const titleParts = dest.titre.split(':');
const titleMain = titleParts[0].trim();
const titleSub = titleParts[1] ? titleParts[1].trim() : '';

// Séparation de la géo-localisation pour styliser le pays en orange ambré
const geoPartsList = dest.geo.split(' // ');

const ratingStars = "★".repeat(Math.round(dest.note)) + "☆".repeat(5 - Math.round(dest.note));

const similarDestinations = destinationsData
  .filter((d) => d.slug !== dest.slug && (d.type.some(t => dest.type.includes(t)) || d.profil.some(p => dest.profil.includes(p))))
  .slice(0, 3);

// ==========================================================================
// 2. ALGORITHME DE SCAN & EXTRACTION AUTOMATIQUE DU BANDEAU D'INFOS (NLP/REGEX)
// ==========================================================================

// Fusion de l'ensemble des textes existants pour analyse de détection (Sans dest.description pour éviter l'erreur TypeScript)
const bodyToScan = `${dest.titre} ${dest.sous_titre} ${dest.stats.duree || ''} ${dest.stats.etapes || ''} ${dest.stats.budget || ''}`.toLowerCase();

// A) Automatisation "Notre séjour" (Durée)
let autoDuree = dest.stats.duree; // Repli par défaut sur le JSON
const dureeRegex = /(\d+)\s*(jours|jours\b|j\b)/g;
const dureeMatch = dureeRegex.exec(bodyToScan);

if (dureeMatch) {
  autoDuree = `${dureeMatch[1]} jours`;
} else if (bodyToScan.includes("semaine")) {
  // Traduction automatique d'expressions courantes
  autoDuree = "7 jours";
}

// B) Automatisation "Itinéraire" (Étapes)
let autoEtapes = dest.stats.etapes; // Repli par défaut sur le JSON
const etapesRegex = /(\d+)\s*(étapes|étape|haltes|arrêts)/g;
const etapesMatch = etapesRegex.exec(bodyToScan);

if (etapesMatch) {
  autoEtapes = `${etapesMatch[1]} étapes`;
}

// C) Automatisation "Budget"
let autoBudget = dest.stats.budget; // Repli par défaut sur le JSON
const budgetRegex = /(~?\s*\d+[\s\d]*)\s*(€|euros)/g;
const budgetMatch = budgetRegex.exec(bodyToScan);

if (budgetMatch) {
  let extractedVal = budgetMatch[1].trim();
  // Standardisation esthétique de l'approximation (tildé)
  if (!extractedVal.startsWith('~') && (bodyToScan.includes('environ') || bodyToScan.includes('budget moyen'))) {
    extractedVal = `~${extractedVal}`;
  }
  // Resserre l'espace dans les grands nombres (ex: 2 100€ -> 2100€ ou 2 100€)
  autoBudget = `${extractedVal}€`.replace(/\s+/g, ' ');
}

// D) Automatisation "Meilleure période" (Dictionnaire de données climatiques)
let autoPeriode = dest.stats.periode; // Repli par défaut sur le JSON
const countryKey = country.toLowerCase().trim();

const climateDatabase: Record<string, string> = {
  'albanie': 'Mai – Sept.',
  'corse': 'Mai – Oct.',
  'chicago': 'Mai – Sept.',
  'usa': 'Mai – Sept.',
  'france': 'Mai – Oct.',
  'italie': 'Avril – Oct.',
  'maroc': 'Oct. – Avril',
  'espagne': 'Mai – Oct.',
  'russie': 'Mai – Sept.',
  'islande': 'Juin – Août'
};

if (climateDatabase[countryKey]) {
  autoPeriode = climateDatabase[countryKey];
}

// E) LOGIQUE D'AUTOMATISATION DES INFOS PRATIQUES (BELGIQUE-CENTRIC)
let docPratique = "Passeport ou carte d'identité en cours de validité (UE). Aucun visa requis.";
let volPratique = "Vols directs ou avec escale depuis la Belgique.";
let deplacerPratique = "Location de voiture recommandée sur place. Réseau de bus limité.";
let monnaiePratique = "Euro (€) fortement conseillé.";

if (dest.slug === 'albanie') {
  docPratique = "Carte d'identité ou passeport en cours de validité pour les ressortissants belges. Aucun visa requis.";
  volPratique = "Environ 2h30 de vol direct depuis l'aéroport de Bruxelles (BRU) ou Charleroi (CRL).";
  deplacerPratique = "Location de voiture indispensable sur place pour explorer l'arrière-pays. Réseau de bus limité.";
  monnaiePratique = "Lek albanais (ALL). L'Euro (€) est également très largement accepté partout sur place.";
} else if (dest.slug === 'corse') {
  docPratique = "Carte d'identité ou passeport en cours de validité. Aucune formalité douanière.";
  volPratique = "Environ 1h45 de vol direct depuis Bruxelles (BRU) ou Charleroi (CRL) vers Bastia/Ajaccio.";
  deplacerPratique = "Location de véhicule (voiture ou scooter) indispensable pour arpenter les routes de montagne.";
  monnaiePratique = "Euro (€). Les cartes bancaires sont acceptées partout, prévoyez un peu de cash.";
} else if (dest.slug === 'chicago') {
  docPratique = "Passeport biométrique valide + autorisation électronique ESTA obligatoire avant l'embarquement.";
  volPratique = "Environ 8h30 de vol direct depuis Bruxelles (BRU) vers Chicago O'Hare (ORD).";
  deplacerPratique = "Réseau de métro (L-Train) et marche à pied recommandés. Voiture déconseillée en ville.";
  monnaiePratique = "Dollar américain (USD). Paiement par carte de crédit ultra-généralisé.";
}
---

<Layout title={`${dest.titre} | The Odyssey`}>
  
  <div class="dest-page-wrapper">
    
    <!-- HERO PLEINE LARGEUR — IMAGE PURE ET TEXTE CENTRÉ -->
    <section class="hero select-none relative h-[560px]">
      <img src={dest.image} alt={dest.titre} class="absolute inset-0 w-full h-full object-cover opacity-90 z-0" />
      <div class="hero-overlay z-10"></div>
      
      <!-- Bouton de retour discret et élégant positionné sous l'en-tête de navigation -->
      <div id="back-to-home-btn" class="hero-back z-30 group/back">
        ← Retour aux destinations
        <span class="absolute bottom-1 left-3 w-0 h-[3px] bg-amber-500/35 transition-all duration-300 group-hover/back:w-[82%] -z-10 rounded-xs"></span>
      </div>
      
      <!-- Cœur favori interactif synchronisé, rehaussé en z-30 pour être cliquable en premier plan -->
      <button id="dest-fav-btn" data-id={dest.slug} class="hero-fav z-30" aria-label="Ajouter aux favoris">
        <svg viewBox="0 0 24 24" class="transition-all duration-300"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>
      
      <div class="hero-content z-20">
        <!-- Localisation géo stylisée (le pays ressort en orange ambré fluide) -->
        <span class="hero-geo uppercase">
          {geoPartsList.map((part, idx) => (
            <>
              {idx > 0 && <span class="geo-sep"> // </span>}
              <span class={idx === geoPartsList.length - 1 ? "geo-country" : "geo-parent"}>{part}</span>
            </>
          ))}
        </span>

        <!-- Titre principal : Avec l'accentuation de thème sur une nouvelle ligne en italique ambré fluide -->
        <h1 class="hero-title">
          {titleMain}
          {titleSub && <span class="hero-title-accent block mt-1.5 sm:mt-2">{titleSub}</span>}
        </h1>

        <!-- Sous-titre automatique en blanc doux pour une visibilité irréprochable -->
        <h2 class="hero-subtitle">{dest.sous_titre}</h2>
        
        <div class="hero-tags">
          {dest.type.map((t) => (
            <span class="hero-tag">
              {t === 'aventure' ? '🥾 Aventure' : t === 'plages' ? '🏖️ Plages' : '🏛️ Culture'}
            </span>
          ))}
          {dest.profil.map((p) => (
            <span class="hero-tag">
              {p === 'couple' ? '👫 Couple' : p === 'famille' ? '👨‍👩‍👧 Famille' : p === 'solo' ? '🧍 Solo' : '👥 Amis'}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- BLOC AUTEUR & STATS AVEC ÉTOILES À GAUCHE ET STATS DYNAMIQUES À DROITE -->
    <div class="author-stats border-b border-[#E0D9D0]">
      <!-- Gauche : Auteur & Avis / Étoiles -->
      <div class="author-part select-none">
        <div class="author-avatar">{dest.auteur.initiale}</div>
        <div>
          <div class="author-name">Récit de {dest.auteur.nom}</div>
          <div class="rating-inline">
            <span class="stars">{ratingStars}</span>
            <span class="rating-count">{dest.note.toFixed(1)} · {dest.nb_avis} avis</span>
          </div>
        </div>
      </div>
      
      <!-- Droite : Stats du séjour (Désormais dynamiques et automatisées) -->
      <div class="stats-right select-none">
        <div class="stat-inline"><span class="text-base block mb-0.5">📅</span><div class="stat-inline-val font-serif font-bold">{autoDuree}</div><div class="stat-inline-lbl">Notre séjour</div></div>
        <div class="sep-v"></div>
        <div class="stat-inline"><span class="text-base block mb-0.5">🗺️</span><div class="stat-inline-val font-serif font-bold">{autoEtapes}</div><div class="stat-inline-lbl">Itinéraire</div></div>
        <div class="sep-v"></div>
        <div class="stat-inline"><span class="text-base block mb-0.5">💶</span><div class="stat-inline-val font-serif font-bold">{autoBudget}</div><div class="stat-inline-lbl">Budget / pers.</div></div>
        <div class="sep-v"></div>
        <div class="stat-inline"><span class="text-base block mb-0.5">🌤️</span><div class="stat-inline-val font-serif font-bold">{autoPeriode}</div><div class="stat-inline-lbl">Meilleure période</div></div>
      </div>
    </div>

    <!-- AGENCEMENT DE LA PAGE -->
    <div class="page max-w-[1600px] mx-auto px-6 sm:px-8 md:px-12 relative overflow-visible">
      
      <!-- TRAJET DU VAN EN SVG MINIMALISTE POINTILLÉ (STICKY À DROITE) -->
      <div class="trail-right hidden lg:block">
        <div class="trail-sticky">
          <svg width="44" height="520" viewBox="0 0 44 520" xmlns="http://www.w3.org/2000/svg" class="overflow-visible">
            <path id="travel-path" d="M22 50 C34 90, 10 130, 22 170 C34 210, 10 250, 22 290 C34 330, 10 370, 22 410 C34 450, 10 490, 22 520"
              fill="none" stroke="#D6CFC4" stroke-width="1.5" stroke-dasharray="4 7" stroke-linecap="round"/>
            <circle cx="22" cy="170" r="3.5" fill="#C8813A" opacity="0.6"/>
            <circle cx="22" cy="290" r="3.5" fill="#C8813A" opacity="0.6"/>
            <circle cx="22" cy="410" r="3.5" fill="#C8813A" opacity="0.6"/>
            <g id="scrolling-van" transform="translate(4, 14)">
              <rect x="0" y="12" width="34" height="16" rx="3" fill="#2C3E50"/>
              <rect x="3" y="4" width="24" height="12" rx="2" fill="#2C3E50"/>
              <rect x="5" y="6" width="9" height="7" rx="1" fill="#F5F2ED" opacity="0.55"/>
              <rect x="16" y="6" width="9" height="7" rx="1" fill="#F5F2ED" opacity="0.55"/>
              <rect x="27" y="5" width="5" height="9" rx="1" fill="#C8813A" opacity="0.7"/>
              <circle cx="8" cy="29" r="4.5" fill="#1a2a38"/>
              <circle cx="8" cy="29" r="2" fill="#D6CFC4"/>
              <circle cx="26" cy="29" r="4.5" fill="#1a2a38"/>
              <circle cx="26" cy="29" r="2" fill="#D6CFC4"/>
              <rect x="3" y="2" width="24" height="2.5" rx="1" fill="#C8813A" opacity="0.85"/>
              <rect x="32" y="14" width="2.5" height="4" rx="0.5" fill="#C8813A" opacity="0.95"/>
              <rect x="32" y="19" width="2.5" height="4" rx="0.5" fill="#C8813A" opacity="0.4"/>
            </g>
          </svg>
        </div>
      </div>

      <!-- CONTENU ÉDITORIAL (À GAUCHE) -->
      <div class="content w-full lg:w-[calc(100%-44px)]">
        
        <!-- NOTRE COUP DE COEUR (Peut être personnalisé via coup_de_coeur_titre/texte dans le JSON) -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="section-label-text">Notre coup de cœur</span>
            <div class="section-line"></div>
          </div>
          <div class="section-title">{dest.coup_de_coeur_titre || "L'île qui résume tout ce qu'on aime dans le voyage"}</div>
          <div class="section-text font-sans">
            {dest.coup_de_coeur_texte || "On ne s'attendait pas à tomber aussi fort pour cette destination. Entre la nature brute qui s'exprime à chaque kilomètre et le lagon turquoise qui appelle au calme, c'est une terre qui réunit tout ce qui nous fait voyager — la force sauvage, l'effort récompensé, et la douceur infinie de l'après."}
          </div>
        </div>

        <!-- NOTRE ITINÉRAIRE (Rapproché du texte et visuels x3 plus grands, dynamique s'il est renseigné dans le JSON) -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="section-label-text">Notre itinéraire</span>
            <div class="section-line"></div>
          </div>

          <!-- Boucle de rendu dynamique des étapes de l'itinéraire s'ils sont renseignés dans le JSON (Commentaires HTML retirés pour la compatibilité JSX d'Astro) -->
          {dest.etapes_details ? (
            dest.etapes_details.map((etape, idx) => (
              <div class="etape pb-6 border-b border-[#E0D9D0]/60 last:border-b-0 last:pb-0">
                <div class="etape-header flex flex-col md:flex-row md:items-center justify-between gap-5 md:gap-6 w-full">
                  <div class="flex items-start gap-3 flex-grow">
                    <div class="etape-num">{idx + 1}</div>
                    <div class="space-y-3">
                      <div class="etape-title font-serif font-bold text-neutral-900 text-base">{etape.titre}</div>
                      <div class="etape-text font-sans max-w-xl">{etape.texte}</div>
                    </div>
                  </div>
                  <div class="w-full md:w-[550px] shrink-0 aspect-[16/10] overflow-hidden rounded-xl border border-[#E0D9D0] shadow-2xs">
                    <img src={etape.image || dest.image} alt={etape.titre} class="w-full h-full object-cover" />
                  </div>
                </div>
              </div>
            ))
          ) : (
            <>
              <div class="etape pb-6 border-b border-[#E0D9D0]/60 last:border-b-0 last:pb-0">
                <div class="etape-header flex flex-col md:flex-row md:items-center justify-between gap-5 md:gap-6 w-full">
                  <div class="flex items-start gap-3 flex-grow">
                    <div class="etape-num">1</div>
                    <div class="space-y-3">
                      <div class="etape-title font-serif font-bold text-neutral-900 text-base">Premier contact & immersion locale — Jours 1 à 3</div>
                      <div class="etape-text font-sans max-w-xl">
                        Notre voyage débute dans la douceur de l'aube. Nous aimons prendre le temps de nous imprégner du climat, d'écouter les bruits de la place principale et de boire un premier café en observant la vie locale s'éveiller. C'est l'étape essentielle pour caler ses pas sur le rythme de la destination.
                      </div>
                    </div>
                  </div>
                  <div class="w-full md:w-[550px] shrink-0 aspect-[16/10] overflow-hidden rounded-xl border border-[#E0D9D0] shadow-2xs">
                    <img src={dest.image} alt="Itinéraire Étape 1" class="w-full h-full object-cover" />
                  </div>
                </div>
              </div>

              <div class="etape pb-6 border-b border-[#E0D9D0]/60 last:border-b-0 last:pb-0">
                <div class="etape-header flex flex-col md:flex-row md:items-center justify-between gap-5 md:gap-6 w-full">
                  <div class="flex items-start gap-3 flex-grow">
                    <div class="etape-num">2</div>
                    <div class="space-y-3">
                      <div class="etape-title font-serif font-bold text-neutral-900 text-base">Les sentiers secrets & panoramas sauvages — Jours 4 à 6</div>
                      <div class="etape-text font-sans max-w-xl">
                        Le seul itinéraire accessible uniquement à pied. Plusieurs jours de marche complète, accueil chaleureux chez l'habitant, repas traditionnels et couchers de soleil spectaculaires depuis les sommets — on en parle encore.
                      </div>
                    </div>
                  </div>
                  <div class="w-full md:w-[550px] shrink-0 aspect-[16/10] overflow-hidden rounded-xl border border-[#E0D9D0] shadow-2xs">
                    <div class="w-full h-full img-ph-1 rounded-xl"></div>
                  </div>
                </div>
              </div>
            </>
          )}
        </div>

        <!-- NOS TROUVAILLES (Dynamique s'il est renseigné dans le JSON) -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="section-label-text">Nos trouvailles</span>
            <div class="section-line"></div>
          </div>
          
          <div class="trouvailles-grid font-mono">
            {dest.trouvailles ? (
              dest.trouvailles.map((t) => (
                <div class="trouvaille-card">
                  <div class="trouvaille-icon">{t.icon}</div>
                  <div class="trouvaille-title font-serif font-bold">{t.titre}</div>
                  <div class="trouvaille-text font-sans">{t.texte}</div>
                </div>
              ))
            ) : (
              <>
                <div class="trouvaille-card">
                  <div class="trouvaille-icon">🍽️</div>
                  <div class="trouvaille-title font-serif font-bold">Le bistrot secret</div>
                  <div class="trouvaille-text font-sans">Petit resto authentique face à la mer, sans carte. Rougail traditionnel à tomber.</div>
                </div>
                <div class="trouvaille-card">
                  <div class="trouvaille-icon">🏄</div>
                  <div class="trouvaille-title font-serif font-bold">Le lagon sauvage</div>
                  <div class="trouvaille-text font-sans">Arriver très tôt le matin. L'eau est d'un calme irréel, idéale pour le snorkeling.</div>
                </div>
                <div class="trouvaille-card">
                  <div class="trouvaille-icon">🏡</div>
                  <div class="trouvaille-title font-serif font-bold">La guesthouse confit</div>
                  <div class="trouvaille-text font-sans">Une demeure en pierres de taille offrant un accueil sincère et des petits déjeuners maison.</div>
                </div>
              </>
            )}
          </div>
        </div>

        <!-- NOS PARTENAIRES -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>

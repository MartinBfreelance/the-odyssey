              </div>
            </div>
          </div>
        </div>

        <!-- BLOC D'AVIS INTERACTIF ET LIGNE VERS INSTAGRAM (Déplacé sous Infos Pratiques et avant les Similaires, sans marge manuelle pour un espacement 100% régulier) -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="section-label-text">Votre avis compte</span>
            <div class="section-line"></div>
          </div>

          <div class="rating-box-container select-none" data-base-note={dest.note} data-base-count={dest.nb_avis} data-slug={dest.slug}>
            <div class="rating-box bg-white border border-[#E0D9D0] rounded-2xl p-6 sm:p-8 flex flex-col md:flex-row items-center justify-between gap-8 shadow-2xs">
              <div class="space-y-3 text-center md:text-left max-w-xl">
                <h3 class="text-base sm:text-lg font-serif font-bold text-neutral-900">Ce guide vous a été utile ?</h3>
                <p class="text-neutral-500 font-sans text-[11px] sm:text-xs leading-relaxed">
                  Nous écrivons ces carnets de route de manière indépendante. Laissez-nous une note pour soutenir notre travail, ou venez nous rejoindre pour échanger directement avec nous sur notre compte Instagram !
                </p>
              </div>
              
              <!-- Zone d'action de notation interactive -->
              <div class="flex flex-col items-center gap-4 shrink-0 min-w-[240px] w-full md:w-auto">
                <!-- Étoiles de notation interactive -->
                <div id="interactive-rating-stars" class="flex items-center gap-2 text-3xl text-neutral-200 cursor-pointer">
                  <span data-star="1" class="interactive-star hover:scale-115 transition-transform duration-150">★</span>
                  <span data-star="2" class="interactive-star hover:scale-115 transition-transform duration-150">★</span>
                  <span data-star="3" class="interactive-star hover:scale-115 transition-transform duration-150">★</span>
                  <span data-star="4" class="interactive-star hover:scale-115 transition-transform duration-150">★</span>
                  <span data-star="5" class="interactive-star hover:scale-115 transition-transform duration-150">★</span>
                </div>
                
                <div id="rating-feedback-msg" class="text-[9px] font-mono uppercase tracking-widest text-neutral-400 h-4">
                  Cliquez pour noter ce guide
                </div>

                <!-- Bouton vers le compte Instagram -->
                <a href="https://instagram.com/the_odyssey_travel_journal" target="_blank" rel="noopener noreferrer" class="partner-cta block text-center select-none w-full py-2.5">
                  Suivre notre aventure sur Instagram 📸
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- SIMILAIRES (Placé en dernier, sous "Votre avis compte", pour clore la page) -->
        <div class="section text-left">
          <div class="section-header group/sec-title">
            <div class="w-5 h-5 text-neutral-400 group-hover/sec-title:rotate-45 group-hover/sec-title:text-amber-600 transition-all duration-500 ease-out shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2" stroke="currentColor"></path>
                <path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
                <path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
              </svg>
            </div>
            <span class="section-label-text">Ces destinations pourraient vous plaire</span>
            <div class="section-line"></div>
          </div>
          <div class="similaires-grid select-none">
            {similarDestinations.map((sim) => (
              <a href={`/destinations/${sim.slug}`} class="sim-card dest-link shadow-2xs hover:shadow-xs transition-shadow block">
                <div class="sim-img relative overflow-hidden bg-neutral-200">
                  <img src={sim.image} alt={sim.titre} class="w-full h-full object-cover transition-transform duration-500 hover:scale-102" />
                </div>
                <div class="sim-body">
                  <div class="sim-region">{sim.geo}</div>
                  <div class="sim-title font-serif font-bold">{sim.titre}</div>
                </div>
              </a>
            ))}
          </div>
          
          <!-- NOUVEAU BOUTON : Voir tous les guides de voyages (Style partner-cta et aligné à gauche) -->
          <div class="text-left mt-6">
            <a href="/#destinations" id="see-all-routes-btn" class="partner-cta inline-block select-none">
              Voir tous les guides de voyages →
            </a>
          </div>
        </div>

      </div>

    </div>
  </div>

  <!-- BOUTON RETOUR EN PIED DE PAGE -->
  <div class="w-full bg-[#FAF9F6] py-16 border-t border-[#E0D9D0] relative z-20">
    <div class="max-w-[1600px] mx-auto px-8 sm:px-12 text-center">
      <a href="/#destinations" class="inline-block text-[10px] font-mono uppercase tracking-[0.25em] bg-neutral-900 text-white font-bold px-8 py-4 rounded-xl hover:bg-amber-600 hover:scale-102 transition-all duration-300 shadow-xs">
        ← Retourner au Tabloir d'Exploration
      </a>
    </div>
  </div>
</Layout>

<!-- FEUILLE DE STYLE LOCALE STRICTE MAQUETTE -->
<style>
  .dest-page-wrapper {
    background-color: #F5F2ED;
    color: #2a2520;
    font-family: 'Playfair Display', Georgia, serif;
  }

  /* Hauteur de 560px pour faire respirer l'image */
  .hero {
    position: relative;
    height: 560px; 
    overflow: hidden;
  }
  
  /* Filtre d'arrière-plan progressif à 3 points pour un contraste optimal */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.4) 0%,     /* Assombrit le haut sous le header fixe */
      rgba(0, 0, 0, 0.25) 45%,   /* Assombrit légèrement le milieu pour détacher les textes */
      rgba(0, 0, 0, 0.5) 100%    /* Assombrit le bas */
    );
    z-index: 10;
  }
  
  /* Bouton retour épuré, élégant, descendu à top 105px */
  .hero-back {
    position: absolute; 
    top: 105px; /* Positionné sous l'en-tête de navigation h-20 (80px) */
    left: 32px;
    display: flex; 
    align-items: center; 
    gap: 6px;
    color: rgba(255, 255, 255, 0.85); 
    font-family: 'Inter', sans-serif; 
    font-size: 9px; 
    letter-spacing: 0.12em; 
    text-transform: uppercase; 
    cursor: pointer;
    background: rgba(0, 0, 0, 0.15); 
    padding: 6px 14px; 
    border-radius: 20px;
    backdrop-filter: blur(4px); 
    border: 1px solid rgba(255, 255, 255, 0.2); 
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    font-weight: 500;
  }
  .hero-back:hover { 
    background: rgba(255, 255, 255, 0.25); 
    color: #ffffff; 
    border-color: rgba(255, 255, 255, 0.6);
    transform: translateY(-1.5px);
  }
  
  /* Style de base pour le cœur favori rehaussé en z-index 30 */
  .hero-fav {
    position: absolute; 
    top: 105px; /* Aligné avec le bouton retour sous l'en-tête */
    right: 32px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(4px);
    transition: all 0.3s ease;
  }
  .hero-fav:hover { 
    transform: scale(1.1); 
    background: rgba(255, 255, 255, 0.3);
  }
  .hero-fav svg { 
    width: 18px; 
    height: 18px; 
    fill: none; 
    stroke: rgba(255, 255, 255, 0.9); 
    stroke-width: 1.8; 
    transition: all 0.3s ease; 
  }
  
  /* Style actif du cœur quand l'itinéraire est dans les favoris */
  .hero-fav.is-active svg {
    fill: #e2b173 !important; /* Remplissage ambre doré fluide assorti */
    stroke: #ffffff !important; /* Contour blanc net */
    stroke-width: 2.2px;
  }
  
  /* Padding-top de 100px pour descendre les textes et libérer de l'espace sous le header fixe */
  .hero-content {
    position: absolute; 
    inset: 0;
    display: flex; 
    flex-direction: column;
    align-items: center; 
    justify-content: center;
    text-align: center; 
    padding: 100px 40px 20px 40px; 
  }
  
  /* Géolocalisation avec séparateurs discrets et pays mis en avant en orange ambré fluide */
  .hero-geo {
    font-family: 'Inter', sans-serif; 
    font-size: 10px; 
    letter-spacing: 0.5em; 
    color: rgba(255, 255, 255, 0.85); 
    text-transform: uppercase; 
    margin-bottom: 16px;
    font-weight: 500;
    display: block;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }
  .geo-parent {
    color: rgba(255, 255, 255, 0.7);
  }
  .geo-sep {
    color: rgba(255, 255, 255, 0.3);
  }
  .geo-country {
    color: #e2b173; /* Ambre doré fluide et soyeux (moins lourd) */
    font-weight: 600;
  }
  
  /* Titre principal : Style serif blanc léger et accentuation ambrée fluide (sans le double point) */
  .hero-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 64px; color: #fff; line-height: 1.15; margin-bottom: 12px;
    font-weight: 300; /* font-light */
    letter-spacing: -0.025em; /* tracking-tight */
    text-shadow: 0 3px 18px rgba(0, 0, 0, 0.6), 0 1px 4px rgba(0, 0, 0, 0.4);
    max-width: 900px;
  }
  .hero-title-accent {
    color: #e2b173; /* Ambre champagne soyeux (visuel haut de gamme et fluide) */
    font-style: italic;
    font-weight: 400;
  }

  /* Sous-titre automatique en blanc doux et en italique (Style serif) */
  .hero-subtitle {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 24px;
    color: rgba(255, 255, 255, 0.95); 
    font-style: italic; /* Italique */
    font-weight: 400; /* font-normal */
    line-height: 1.35;
    margin-bottom: 24px;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.65), 0 1px 4px rgba(0, 0, 0, 0.4);
    max-width: 800px;
  }

  .hero-tags { display: flex; gap: 8px; justify-content: center; }
  .hero-tag {
    font-family: 'Inter', sans-serif; font-size: 8px; letter-spacing: 1px;
    padding: 4px 12px; border-radius: 12px;
    background: rgba(255,255,255,0.18); color: rgba(255,255,255,0.9);
    text-transform: uppercase; backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.2);
  }

  /* BARRE FUSIONNÉE : ÉTOILES À GAUCHE, DETAILS À DROITE */
  .author-stats {
    background: #fff; border-bottom: 1px solid #E0D9D0;
    padding: 16px 40px; display: flex; align-items: center;
    justify-content: space-between; gap: 20px; flex-wrap: wrap;
  }
  .author-part { display: flex; align-items: center; gap: 10px; }
  .author-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, #C8813A, #8a5a2a);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 14px; flex-shrink: 0;
  }
  .author-name { font-family: 'Inter', sans-serif; font-size: 10px; letter-spacing: 1px; color: #2C3E50; text-transform: uppercase; font-weight: 600; }
  
  /* Intégration des avis à la place de l'année */
  .rating-inline { display: flex; align-items: center; gap: 6px; margin-top: 2px; }
  .stars { color: #C8813A; font-size: 11px; letter-spacing: 1px; }
  .rating-count { font-family: 'Inter', sans-serif; font-size: 9px; color: #9a9088; }

  /* Regroupement des stats à droite */
  .stats-right { display: flex; align-items: center; flex-wrap: wrap; }
  .sep-v { width: 1px; height: 32px; background: #E0D9D0; margin: 0 18px; flex-shrink: 0; }
  .stat-inline { display: flex; flex-direction: column; align-items: center; padding: 0 12px; }
  .stat-inline-val { font-size: 13px; color: #2C3E50; font-weight: 700; }
  .stat-inline-lbl { font-family: 'Inter', sans-serif; font-size: 7.5px; letter-spacing: 1px; color: #b0a898; text-transform: uppercase; margin-top: 2px; }

  /* PAGE LAYOUT */
  .page { display: flex; position: relative; padding: 40px 0; }

  /* VAN CÔTÉ DROIT */
  .trail-right { position: absolute; right: 8px; top: 0; bottom: 0; width: 44px; pointer-events: none; z-index: 10; }
  .trail-sticky { position: sticky; top: 120px; } 

  /* CONTENT */
  .content { flex: 1; padding: 28px 64px 0 40px; }
  @media (max-width: 1024px) {
    .content { padding: 28px 32px 0 32px; }
  }

  /* SECTION TITLES */
  .section-header {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 14px; cursor: default;
  }
  .compass {
    width: 22px; height: 22px; flex-shrink: 0;
    transition: transform 0.6s ease;
  }
  .section-header:hover .compass { transform: rotate(180deg); }
  .section-label-text {
    font-family: 'Inter', sans-serif; font-size: 9.5px; letter-spacing: 2.5px;
    color: #C8813A; text-transform: uppercase; font-weight: 600;
    position: relative; padding-bottom: 2px;
  }
  .section-label-text::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 0; height: 1.5px; background: #C8813A;
    transition: width 0.3s ease;
  }
  .section-header:hover .section-label-text::after { width: 100%; }
  .section-line { flex: 1; height: 1px; background: #E0D9D0; }
  
  /* Espacement global régulier appliqué à chaque bloc de section de la page d'un Onepager */
  .section { margin-bottom: 28px; }
  .section-title { font-size: 19px; color: #2a2520; margin-bottom: 8px; font-weight: normal; line-height: 1.3; }
  .section-text { font-family: 'Inter', sans-serif; font-size: 11px; color: #5a5248; line-height: 1.8; }

  /* ÉTAPES */
  .etape { margin-bottom: 22px; }
  .etape-header { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
  .etape-num {
    width: 26px; height: 26px; border-radius: 50%; background: #2C3E50;
    color: #fff; font-family: 'Inter', sans-serif; font-size: 10px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;
  }
  .etape-title { font-size: 14px; color: #2a2520; margin-bottom: 4px; }
  .etape-text { font-family: 'Inter', sans-serif; font-size: 10.5px; color: #5a5248; line-height: 1.7; }
  
  .etape-media {
    display: grid; gap: 14px; margin-top: 12px; margin-left: 38px;
  }
  .etape-media.media-left { grid-template-columns: 320px 1fr; }
  .etape-media.media-right { grid-template-columns: 1fr 320px; }
  .etape-media.media-none { display: none; }
  
  .media-img { border-radius: 10px; overflow: hidden; border: 1px solid #E0D9D0; }
  .media-img-ph { height: 180px; border-radius: 10px; }
  .ph-1 { background: linear-gradient(135deg, #4a7c59, #1a3d2a); }
  .ph-2 { background: linear-gradient(135deg, #7a5a3a, #3a2a1a); }
  .media-caption { font-family: 'Inter', sans-serif; font-size: 9px; color: #9a9088; margin-top: 5px; font-style: italic; text-align: center; }
  .etape-text-block { display: flex; flex-direction: column; justify-content: center; }

  /* TROUVAILLES */
  .trouvailles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .trouvaille-card { background: #fff; border: 1px solid #E0D9D0; border-radius: 12px; padding: 14px; transition: box-shadow 0.2s; }
  .trouvaille-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
  .trouvaille-icon { font-size: 20px; margin-bottom: 7px; }
  .trouvaille-title { font-size: 12px; color: #2a2520; margin-bottom: 4px; }
  .trouvaille-text { font-family: 'Inter', sans-serif; font-size: 9.5px; color: #7a7060; line-height: 1.6; }

  /* PARTENAIRES */
  .partner-block { background: #fff; border: 1px solid #E0D9D0; border-radius: 12px; padding: 16px; display: flex; align-items: center; gap: 14px; margin-bottom: 10px; transition: box-shadow 0.2s; }
  .partner-block:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
  .partner-icon { font-size: 26px; flex-shrink: 0; }
  .partner-label { font-family: 'Inter', sans-serif; font-size: 8px; letter-spacing: 1.5px; color: #C8813A; text-transform: uppercase; margin-bottom: 3px; }
  .partner-title { font-size: 13px; color: #2a2520; margin-bottom: 3px; }
  .partner-text { font-family: 'Inter', sans-serif; font-size: 9.5px; color: #7a7060; line-height: 1.5; }
  .partner-cta { background: #C8813A; color: #fff; font-family: 'Inter', sans-serif; font-size: 8.5px; letter-spacing: 1.5px; text-transform: uppercase; border: none; border-radius: 20px; padding: 8px 14px; cursor: pointer; white-space: nowrap; flex-shrink: 0; transition: background 0.2s; text-decoration: none; }
  .partner-cta:hover { background: #2C3E50; }

  /* PRATIQUE */
  .pratique-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .pratique-item { background: #fff; border: 1px solid #E0D9D0; border-radius: 10px; padding: 12px; display: flex; gap: 8px; }
  .pratique-icon { font-size: 15px; flex-shrink: 0; }
  .pratique-label { font-family: 'Inter', sans-serif; font-size: 8px; letter-spacing: 1px; color: #C8813A; text-transform: uppercase; margin-bottom: 2px; }
  .pratique-text { font-family: 'Inter', sans-serif; font-size: 10px; color: #5a5248; line-height: 1.5; }

  /* SIMILAIRES : Agrandissement de la hauteur des cartes pour gommer le vide et dynamiser le rendu */
  .similaires-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .sim-card { background: #fff; border: 1px solid #E0D9D0; border-radius: 10px; overflow: hidden; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; text-decoration: none; }
  .sim-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
  .sim-img { height: 160px; } /* Augmenté de 100px à 160px pour une visibilité accrue des photos */
  .sim-body { padding: 10px; }
  .sim-region { font-family: 'Inter', sans-serif; font-size: 7.5px; letter-spacing: 1px; color: #C8813A; text-transform: uppercase; margin-bottom: 3px; }
  .sim-title { font-family: 'Playfair Display', Georgia, serif; font-size: 11px; color: #2a2520; }

  /* RESPONSIVE AJUSTEMENTS BARRES ET TITRES */
  @media (max-width: 1024px) {
    .author-stats {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      padding: 20px;
    }
    .stats-right {
      width: 100%;
      justify-content: space-between;
    }
  }
  @media (max-width: 640px) {
    .hero-title {
      font-size: 44px;
    }
    .hero-subtitle {
      font-size: 18px;
    }
    .stats-right {
      gap: 10px;
    }
    .sep-v {
      display: none;
    }
    .stat-inline {
      padding: 0 6px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pageEl = document.querySelector('.page') as HTMLElement | null;
    const van = document.getElementById('scrolling-van') as SVGGraphicsElement | null;
    const path = document.getElementById('travel-path') as SVGPathElement | null;
    const destFavBtn = document.getElementById('dest-fav-btn') as HTMLButtonElement | null;
    const backBtn = document.getElementById('back-to-home-btn') as HTMLDivElement | null;

    // 1. ANIMATION DU VAN SVG AU SCROLL
    if (pageEl && van && path) {
      const pathLength = path.getTotalLength();
      
      const animateVan = () => {
        const scrollY = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        
        let scrollPercent = scrollY / (docHeight || 1);
        scrollPercent = Math.min(Math.max(scrollPercent, 0), 1);
        
        const point = path.getPointAtLength(scrollPercent * pathLength);
        
        // Centre l'icône du van sur la courbe de Bézier
        van.setAttribute('transform', `translate(${point.x - 17}, ${point.y - 15})`);
      };

      window.addEventListener('scroll', animateVan, { passive: true });
      animateVan();
    }

    // 2. RETOUR CONTEXTUALISÉ ET RESTAURATION DE SESSION
    if (backBtn) {
      backBtn.addEventListener('click', (e) => {
        e.preventDefault();
        try {
          sessionStorage.removeItem('odyssey_home_scroll'); // On efface la mémoire de défilement pour forcer l'ancre #destinations
          sessionStorage.removeItem('odyssey_home_filter'); // Optionnel
        } catch (err) {}
        window.location.href = '/#destinations';
      });
    }

    // 3. SYNCHRONISATION DU BOUTON FAVORIS LOCAL DE LA CARD ET DU MENU SUPERIEUR
    if (destFavBtn) {
      const cardId = destFavBtn.getAttribute('data-id');

      const getFavorites = (): string[] => {
        try {
          const stored = localStorage.getItem('the_odyssey_favorites');
          return stored ? JSON.parse(stored) : [];
        } catch (e) { return []; }
      };

      const isFavorite = (id: string) => getFavorites().includes(id);

      const updateFavButtonUI = () => {
        if (!cardId) return;
        
        const favs = getFavorites();
        const svg = destFavBtn.querySelector('svg');
        if (svg) {
          if (isFavorite(cardId)) {
            destFavBtn.classList.add('is-active');
            svg.setAttribute('stroke-width', '2.2'); // Même valeur que le CSS
          } else {
            destFavBtn.classList.remove('is-active');
            svg.setAttribute('stroke-width', '1.8');
          }
        }

        // Mettre à jour également le cœur et le point rouge du menu de navigation fixe tout en haut
        const menuBtn = document.getElementById('favorites-menu-btn');
        const menuSvg = menuBtn ? menuBtn.querySelector('svg') : null;
        const dot = document.getElementById('favorites-dot');
        
        if (menuSvg) {
          if (favs.length > 0) {
            menuSvg.classList.add('text-amber-500', 'fill-amber-500', 'stroke-white');
            menuSvg.classList.remove('text-white');
            menuSvg.setAttribute('stroke-width', '2.5');
          } else {
            menuSvg.classList.remove('text-amber-500', 'fill-amber-500', 'stroke-white');
            menuSvg.classList.add('text-white');
            menuSvg.setAttribute('stroke-width', '1.8');
          }
        }

        if (dot) {
          if (favs.length > 0) {
            dot.classList.add('scale-100', 'opacity-100');
            dot.classList.remove('scale-0', 'opacity-0');
          } else {
            dot.classList.add('scale-0', 'opacity-0');
            dot.classList.remove('scale-100', 'opacity-100');
          }
        }
      };

      destFavBtn.addEventListener('click', () => {
        if (!cardId) return;
        let favs = getFavorites();
        if (favs.includes(cardId)) {
          favs = favs.filter(id => id !== cardId);
        } else {
          favs.push(cardId);
        }
        localStorage.setItem('the_odyssey_favorites', JSON.stringify(favs));
        updateFavButtonUI();
      });

      // Permettre au clic sur le bouton de favoris du menu supérieur de rediriger vers la home filtrée
      const menuBtn = document.getElementById('favorites-menu-btn');
      if (menuBtn) {
        menuBtn.addEventListener('click', (e) => {
          e.preventDefault();
          try {
            sessionStorage.setItem('odyssey_home_filter', 'favorites');
          } catch (err) {}
          window.location.href = '/#destinations';
        });
      }

      updateFavButtonUI();
    }

    // 4. SYSTÈME INTERACTIF D'AVIS ET DE NOTATION RÉACTIF (LOCAL STORAGE)
    const ratingContainer = document.querySelector('.rating-box-container') as HTMLElement | null;
    if (ratingContainer) {
      const slug = ratingContainer.getAttribute('data-slug') || '';
      const baseNote = parseFloat(ratingContainer.getAttribute('data-base-note') || '0');
      const baseCount = parseInt(ratingContainer.getAttribute('data-base-count') || '0');
      const starsContainer = document.getElementById('interactive-rating-stars');
      const feedbackMsg = document.getElementById('rating-feedback-msg');
      const headerStarsEl = document.querySelector('.author-stats .stars');
      const headerCountEl = document.querySelector('.author-stats .rating-count');

      const stars = starsContainer ? starsContainer.querySelectorAll('.interactive-star') : [];

      const getVote = () => {
        try {
          return localStorage.getItem(`vote_${slug}`);
        } catch(e) { return null; }
      };

      const setVote = (val: number) => {
        try {
          localStorage.setItem(`vote_${slug}`, val.toString());
        } catch(e) {}
      };

      const updateHeaderRating = (votedVal: number) => {
        if (!headerStarsEl || !headerCountEl) return;
        const newCount = baseCount + 1;
        const newNote = ((baseNote * baseCount) + votedVal) / newCount;
        
        // Génération visuelle des étoiles
        const roundedNote = Math.round(newNote);
        const newStars = "★".repeat(roundedNote) + "☆".repeat(5 - Math.round(newNote));
        
        headerStarsEl.textContent = newStars;
        headerCountEl.textContent = `${newNote.toFixed(1)} · ${newCount} avis`;

        // Petite animation de flash/surbrillance ambrée sur la barre de stats pour valider visuellement le vote
        const authorStatsBar = document.querySelector('.author-stats');
        if (authorStatsBar) {
          authorStatsBar.classList.add('scale-[1.01]', 'border-amber-500', 'transition-all', 'duration-300');
          setTimeout(() => {
            authorStatsBar.classList.remove('scale-[1.01]', 'border-amber-500');
          }, 600);
        }
      };

      const highlightStars = (count: number, activeColor = '#e2b173', inactiveColor = '#e5e5e5') => {
        stars.forEach((star, idx) => {
          const starEl = star as HTMLElement;
          if (idx < count) {
            starEl.style.color = activeColor;
            starEl.classList.add('text-amber-500');
          } else {
            starEl.style.color = inactiveColor;
            starEl.classList.remove('text-amber-500');
          }
        });
      };

      const initRatingSystem = () => {
        // Gérer l'état de survol (hover) et le clic interactif à tout moment (modifications infinies autorisées)
        stars.forEach((star, idx) => {
          const starEl = star as HTMLElement;
          
          starEl.addEventListener('mouseenter', () => {
            highlightStars(idx + 1, '#e2b173', '#e5e5e5');
            if (feedbackMsg) feedbackMsg.textContent = `Donner ${idx + 1} étoile${idx > 0 ? 's' : ''}`;
          });

          starEl.addEventListener('mouseleave', () => {
            const currentVote = getVote();
            if (currentVote) {
              const voteVal = parseInt(currentVote);
              highlightStars(voteVal, '#e2b173', '#e5e5e5');
              if (feedbackMsg) feedbackMsg.textContent = `Votre note enregistrée (${voteVal}/5) - Cliquez pour modifier`;
            } else {
              highlightStars(0);
              if (feedbackMsg) feedbackMsg.textContent = 'Cliquez pour noter ce guide';
            }
          });

          // Action de clic pour enregistrer et modifier le choix à tout moment
          starEl.addEventListener('click', () => {
            const voteVal = idx + 1;
            setVote(voteVal);
            highlightStars(voteVal, '#e2b173', '#e5e5e5');
            if (feedbackMsg) feedbackMsg.textContent = `Merci ! Note enregistrée (${voteVal}/5) - Cliquez pour modifier`;
            updateHeaderRating(voteVal);
          });
        });

        // Initialisation de l'état d'un vote existant lors du chargement de la page
        const existingVote = getVote();
        if (existingVote) {
          const voteVal = parseInt(existingVote);
          highlightStars(voteVal, '#e2b173', '#e5e5e5');
          if (feedbackMsg) feedbackMsg.textContent = `Votre note enregistrée (${voteVal}/5) - Cliquez pour modifier`;
          updateHeaderRating(voteVal);
        }
      };

      initRatingSystem();
    }

    // 5. GESTION DU RETOUR DU BOUTON SOUS LES SIMILAIRES
    const seeAllBtn = document.getElementById('see-all-routes-btn');
    if (seeAllBtn) {
      seeAllBtn.addEventListener('click', () => {
        try {
          sessionStorage.removeItem('odyssey_home_scroll');
          sessionStorage.removeItem('odyssey_home_filter');
        } catch(err) {}
      });
    }
  });
</script>
---
import Layout from '../../layouts/Layout.astro';
import destinationsData from '../../data/destinations.json';

// Configuration du routage dynamique Astro
export async function getStaticPaths() {
  return destinationsData.map((dest) => ({
    params: { slug: dest.slug },
    props: { dest },
  }));
}

const { dest } = Astro.props;

// 1. SÉCURISATION & EN-TÊTE [5]
// Validation du format du slug par regex strict (minuscules, chiffres, tirets)
const slugRegex = /^[a-z0-9\-]+$/;
if (!slugRegex.test(dest.slug)) {
  return Astro.redirect('/404');
}

// Validation des liens d'affiliation par liste blanche
const allowedDomains = ["booking.com", "nomadesim.com", "chapkadirect.fr"];
const validateLink = (urlStr: string) => {
  try {
    const url = new URL(urlStr);
    return allowedDomains.some(domain => url.hostname === domain || url.hostname.endsWith('.' + domain));
  } catch(e) {
    return false;
  }
};

const bookingLink = validateLink(dest.liens.booking) ? dest.liens.booking : "https://booking.com";
const esimLink = validateLink(dest.liens.esim) ? dest.liens.esim : "https://www.nomadesim.com/";

// Extraction dynamique des données géographiques d'Ariane
const country = dest.geo.split(' // ').pop() || 'Exploration';
const zone = dest.geo.split(' // ')[1] || 'Zone';
const continent = dest.geo.split(' // ')[0] || 'Continent';

// Calcul des 3 destinations similaires partageant au moins une ambiance ou un profil commun
const similarDestinations = destinationsData
  .filter((d) => d.slug !== dest.slug && (d.type.some(t => dest.type.includes(t)) || d.profil.some(p => dest.profil.includes(p))))
  .slice(0, 3);
---

<Layout title={`${dest.titre} | The Odyssey`}>
  
  <!-- HERO IMAGE FULL-WIDTH -->
  <section class="relative w-full h-[65vh] bg-[#2C3E50] overflow-hidden flex items-end select-none">
    <div class="absolute inset-0 z-0">
      <img src={dest.image} alt={dest.titre} class="w-full h-full object-cover opacity-60" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-950/80 via-neutral-950/20 to-transparent z-10"></div>
    </div>

    <!-- ÉLÉMENTS DE CONTEXTE GAUCHE (Bouton retour & Fil d'Ariane) -->
    <div class="absolute top-24 left-8 sm:left-12 z-20 flex flex-col gap-4 font-mono text-[9px] tracking-widest uppercase">
      <!-- Bouton retour préservant l'état exact de l'utilisateur (filtres, scroll) -->
      <a 
        href="/#destinations" 
        id="back-to-home-btn"
        class="flex items-center space-x-2 text-white bg-black/40 hover:bg-black/60 backdrop-blur-md px-5 py-2.5 rounded-full border border-white/10 transition-all duration-300 scale-100 hover:scale-102 cursor-pointer shadow-sm w-max"
      >
        <span>← Retour</span>
      </a>

      <!-- Fil d'Ariane -->
      <span class="text-neutral-300/80 mt-2 select-none">
        Home // Destinations // <span class="text-white">{continent}</span> // <span class="text-amber-500">{country}</span>
      </span>
    </div>

    <!-- Cœur favori en haut à droite, synchronisé avec la Home -->
    <button 
      id="dest-fav-btn" 
      data-id={dest.slug}
      class="absolute top-24 right-8 sm:right-12 z-20 p-3 rounded-full bg-white/10 border border-white/20 backdrop-blur-md text-white/90 hover:scale-110 active:scale-95 transition-all duration-300 shadow-sm cursor-pointer"
      aria-label="Ajouter aux favoris"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 transition-all duration-300">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
      </svg>
    </button>

    <!-- TEXTE PRINCIPAL HERO (Georgia serif, Ambiance & Profil pills) -->
    <div class="relative z-20 max-w-4xl mx-auto w-full px-8 sm:px-12 pb-12 text-white space-y-3">
      <span class="text-[10px] font-mono tracking-[0.4em] uppercase text-amber-500">{dest.geo}</span>
      <h1 class="text-3xl sm:text-5xl md:text-6xl font-serif font-light leading-tight drop-shadow-md">{dest.titre}</h1>
      <p class="text-neutral-200/90 max-w-xl text-xs sm:text-sm font-light italic leading-relaxed">{dest.sous_titre}</p>

      <!-- Tags Pills -->
      <div class="flex flex-wrap gap-2 pt-4">
        {dest.type.map((t) => (
          <span class="text-[9px] font-mono tracking-widest uppercase bg-white/10 backdrop-blur-sm border border-white/15 px-3 py-1.5 rounded-full">
            {t === 'aventure' ? '🥾 Aventure & Trek' : t === 'plages' ? '🏖️ Plage & Farniente' : '🏛️ Villes & Culture'}
          </span>
        ))}
        {dest.profil.map((p) => (
          <span class="text-[9px] font-mono tracking-widest uppercase bg-white/10 backdrop-blur-sm border border-white/15 px-3 py-1.5 rounded-full">
            {p === 'couple' ? '👫 Couple' : p === 'famille' ? '👨‍👩‍👧 Famille' : p === 'solo' ? '🧍 Solo' : '👥 Amis'}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- BARRE AUTEUR -->
  <div class="w-full bg-white border-b border-[#E0D9D0] py-4 px-8 sm:px-12 relative z-20 font-mono text-[9px] tracking-widest text-[#5a5248]">
    <div class="max-w-[1600px] mx-auto flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div class="flex items-center space-x-3">
        <div class="w-8 h-8 rounded-full bg-[#2C3E50] text-white flex items-center justify-center font-bold text-xs select-none">
          {dest.auteur.initiale}
        </div>
        <div>
          <span class="font-bold text-[#2a2520]">{dest.auteur.nom}</span>
          <span class="mx-2 text-neutral-300">|</span>
          <span>Publié le {dest.auteur.date}</span>
          <span class="mx-2 text-neutral-300">|</span>
          <span>Lecture : {dest.auteur.lecture}</span>
        </div>
      </div>
      <!-- Système de notation étoiles ambrées -->
      <div class="flex items-center space-x-1 select-none">
        <span class="text-amber-500 text-xs">★ ★ ★ ★ ★</span>
        <span class="font-bold text-[#2a2520] pl-1">{dest.note.toFixed(1)}</span>
        <span class="text-neutral-400">({dest.nb_avis} avis)</span>
      </div>
    </div>
  </div>

  <!-- CONTENU PRINCIPAL + DISPOSITIF STICKY VAN (Palette #F5F2ED) -->
  <div class="w-full bg-[#F5F2ED] py-16 sm:py-20 relative z-10 text-[#2a2520]">
    <div class="max-w-[1600px] mx-auto px-8 sm:px-12 grid grid-cols-1 xl:grid-cols-12 gap-12 items-start relative overflow-visible">
      
      <!-- CONTENU GAUCHE (9 COLONNES) -->
      <div class="xl:col-span-9 space-y-16">
        
        <!-- BLOC NOTRE COUP DE COEUR -->
        <section class="space-y-4 text-left">
          <div class="flex items-center space-x-3">
            <span class="text-[9px] font-mono tracking-[0.4em] uppercase text-amber-600 font-bold">Notre coup de cœur</span>
            <div class="h-[1px] bg-[#E0D9D0] flex-grow"></div>
          </div>
          <p class="font-serif italic text-lg sm:text-xl md:text-2xl text-[#2C3E50] leading-relaxed">
            « Nous avons été profondément saisis par la sincérité de ces paysages. Loin des sentiers balisés, chaque virage nous offrait une nouvelle rencontre, une ruelle pavée de pierres centenaires ou une vue plongeante sur l'azur infini. C'est l'essence même du voyage lent que nous chérissons tant. »
          </p>
        </section>

        <!-- BLOC STATS ESSENTIEL EN 4 COLONNES RIGIDES -->
        <section class="space-y-4">
          <div class="flex items-center space-x-3">
            <span class="text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-900 font-bold">L'Essentiel en un clin d'œil</span>
            <div class="h-[1px] bg-[#E0D9D0] flex-grow"></div>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6 font-mono text-[9px] tracking-wider text-left">
            <div class="border border-[#E0D9D0] p-5 bg-white rounded-xl space-y-1.5 shadow-2xs">
              <p class="text-neutral-400 font-bold uppercase">Durée du séjour</p>
              <p class="text-xs sm:text-sm text-[#2C3E50] font-bold">{dest.stats.duree}</p>
            </div>
            <div class="border border-[#E0D9D0] p-5 bg-white rounded-xl space-y-1.5 shadow-2xs">
              <p class="text-neutral-400 font-bold uppercase">Itinéraire</p>
              <p class="text-xs sm:text-sm text-[#2C3E50] font-bold">{dest.stats.etapes}</p>
            </div>
            <div class="border border-[#E0D9D0] p-5 bg-white rounded-xl space-y-1.5 shadow-2xs">
              <p class="text-neutral-400 font-bold uppercase">Budget Indicatif</p>
              <p class="text-xs sm:text-sm text-[#2C3E50] font-bold">{dest.stats.budget} / pers.</p>
            </div>
            <div class="border border-[#E0D9D0] p-5 bg-white rounded-xl space-y-1.5 shadow-2xs">
              <p class="text-neutral-400 font-bold uppercase">Meilleure période</p>
              <p class="text-xs sm:text-sm text-[#2C3E50] font-bold">{dest.stats.periode}</p>
            </div>
          </div>
        </section>

        <!-- BLOC ITINÉRAIRE (Étapes numérotées) -->
        <section class="space-y-8 text-left">
          <div class="flex items-center space-x-3">
            <span class="text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-900 font-bold">Le tracé de notre exploration</span>
            <div class="h-[1px] bg-[#E0D9D0] flex-grow"></div>
          </div>
          
          <div class="space-y-12">
            <!-- Étape 1 -->
            <div class="flex items-start space-x-6">
              <div class="w-8 h-8 rounded-full bg-[#2C3E50] text-white flex items-center justify-center font-bold text-xs shrink-0 select-none">1</div>
              <div class="space-y-3">
                <h3 class="font-serif text-base sm:text-lg text-neutral-900 font-bold leading-none">Premier contact & immersion locale</h3>
                <p class="text-xs text-[#5a5248] font-light leading-relaxed font-sans">
                  Notre voyage débute dans la douceur de l'aube. Nous aimons prendre le temps de nous imprégner du climat, d'écouter les bruits de la place principale et de boire un premier café en observant la vie locale s'éveiller. C'est l'étape essentielle pour caler ses pas sur le rythme de la destination.
                </p>
              </div>
            </div>

            <!-- Étape 2 -->
            <div class="flex items-start space-x-6">
              <div class="w-8 h-8 rounded-full bg-[#2C3E50] text-white flex items-center justify-center font-bold text-xs shrink-0 select-none">2</div>
              <div class="space-y-3">
                <h3 class="font-serif text-base sm:text-lg text-neutral-900 font-bold leading-none">Les sentiers secrets & panoramas sauvages</h3>
                <p class="text-xs text-[#5a5248] font-light leading-relaxed font-sans">
                  Nous nous écartons des axes principaux pour emprunter des sentiers côtiers ou de montagne. Le silence n'est rompu que par la nature, et chaque point de vue sur l'horizon devient une récompense méritée pour l'effort fourni.
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- BLOC TROUVAILLES LOCALES (Grille 3 Colonnes de cartes blanches) -->
        <section class="space-y-6 text-left">
          <div class="flex items-center space-x-3">
            <span class="text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-900 font-bold">Nos adresses de confiance</span>
            <div class="h-[1px] bg-[#E0D9D0] flex-grow"></div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 font-mono text-[9px] tracking-wider">
            <div class="border border-[#E0D9D0] p-6 bg-white rounded-xl space-y-3 shadow-2xs">
              <p class="text-amber-600 uppercase font-bold">🍽️ Le bistrot secret</p>
              <p class="text-[#5a5248] font-light leading-relaxed tracking-normal text-[11px] font-sans">Une table de trois couverts sur une terrasse ombragée, gérée par une famille passionnée.</p>
            </div>
            <div class="border border-[#E0D9D0] p-6 bg-white rounded-xl space-y-3 shadow-2xs">
              <p class="text-amber-600 uppercase font-bold">🌄 Le spot coucher de soleil</p>
              <p class="text-[#5a5248] font-light leading-relaxed tracking-normal text-[11px] font-sans">Une falaise discrète accessible après 20 minutes de marche à l'écart de la foule.</p>
            </div>
            <div class="border border-[#E0D9D0] p-6 bg-white rounded-xl space-y-3 shadow-2xs">
              <p class="text-amber-600 uppercase font-bold">🏡 La guesthouse confit</p>
              <p class="text-[#5a5248] font-light leading-relaxed tracking-normal text-[11px] font-sans">Une demeure en pierres de taille offrant un accueil sincère et des petits déjeuners maison.</p>
            </div>
          </div>
        </section>

        <!-- BLOC PARTENAIRES AFFILIÉS SÉCURISÉ [5] -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-6 font-mono text-[9px] tracking-wider text-left">
          <!-- Logement -->
          <div class="border border-[#E0D9D0] p-6 bg-white rounded-xl space-y-4 shadow-2xs flex flex-col justify-between">
            <div class="space-y-2">
              <p class="text-amber-600 uppercase font-bold">🏢 Où dormir</p>
              <h3 class="font-serif text-sm text-[#2C3E50] font-light">Notre Sélection d'Hôtels de Charme</h3>
              <p class="text-neutral-500 leading-relaxed font-sans text-xs tracking-normal">Réservez vos hébergements de charme via notre sélection d'adresses approuvées sur le terrain.</p>
            </div>
            <a href={bookingLink} target="_blank" rel="noopener noreferrer" class="text-neutral-900 font-bold uppercase tracking-widest border-b border-neutral-950 pb-0.5 hover:text-amber-600 hover:border-amber-600 transition-all inline-block w-max">Trouver son logement →</a>
          </div>

          <!-- eSIM -->
          <div class="border border-[#E0D9D0] p-6 bg-white rounded-xl space-y-4 shadow-2xs flex flex-col justify-between">
            <div class="space-y-2">
              <p class="text-amber-600 uppercase font-bold">📶 Activer son eSIM</p>
              <h3 class="font-serif text-sm text-[#2C3E50] font-light">Forfait international local</h3>
              <p class="text-neutral-500 leading-relaxed font-sans text-xs tracking-normal">Activez instantanément votre connexion internet locale dès votre arrivée pour voyager sereinement.</p>
            </div>
            <a href={esimLink} target="_blank" rel="noopener noreferrer" class="text-neutral-900 font-bold uppercase tracking-widest border-b border-neutral-950 pb-0.5 hover:text-amber-600 hover:border-amber-600 transition-all inline-block w-max">Activer son eSIM Nomad →</a>
          </div>
        </section>

        <!-- BLOC INFOS PRATIQUES (Grille 2 Colonnes) -->
        <section class="space-y-6 text-left">
          <div class="flex items-center space-x-3">
            <span class="text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-900 font-bold">Informations Pratiques</span>
            <div class="h-[1px] bg-[#E0D9D0] flex-grow"></div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 font-mono text-[9px] tracking-wider">
            <div class="space-y-2">
              <p class="text-amber-600 font-bold uppercase">🛂 Visa & Formalités</p>
              <p class="text-xs text-[#5a5248] font-sans font-light leading-relaxed">Passeport en cours de validité requis pour les ressortissants de l'Union Européenne. Aucun visa nécessaire pour les séjours de moins de 90 jours.</p>
            </div>
            <div class="space-y-2">
              <p class="text-amber-600 font-bold uppercase">🚊 Se Déplacer</p>
              <p class="text-xs text-[#5a5248] font-sans font-light leading-relaxed">La location d'un véhicule léger reste le moyen le plus adapté pour explorer les parcs et villages à votre rythme.</p>
            </div>
          </div>
        </section>

        <!-- BLOC DESTINATIONS SIMILAIRES -->
        <section class="space-y-6 text-left">
          <div class="flex items-center space-x-3">
            <span class="text-[9px] font-mono tracking-[0.4em] uppercase text-neutral-900 font-bold">Poursuivre l'Exploration</span>
            <div class="h-[1px] bg-[#E0D9D0] flex-grow"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            {similarDestinations.map((sim) => (
              <a href={`/destinations/${sim.slug}`} class="group flex flex-col justify-between h-full bg-[#FFFFFF] border border-neutral-200/40 rounded-xl overflow-hidden shadow-2xs hover:shadow-xs transition-shadow">
                <div class="aspect-[16/10] overflow-hidden bg-neutral-100">
                  <img src={sim.image} alt={sim.titre} class="w-full h-full object-cover group-hover:scale-101 transition-transform duration-500" />
                </div>
                <div class="p-4 space-y-2">
                  <span class="text-[7px] font-mono text-neutral-400 uppercase tracking-widest block">{sim.geo}</span>
                  <h4 class="text-xs font-serif font-light text-neutral-900 group-hover:text-amber-800 transition-colors">{sim.titre}</h4>
                </div>
              </a>
            ))}
          </div>
        </section>

      </div>

      <!-- COLONNE DROITE (Van SVG Minimaliste sur tracé zigzag pointillé) [4] -->
      <aside class="lg:col-span-3 hidden lg:block sticky top-28 h-[80vh] flex flex-col items-center justify-between select-none">
        <div class="relative w-full h-full flex flex-col items-center justify-center">
          
          <!-- Ligne de trajet pointillée en zigzag vertical -->
          <svg class="absolute inset-x-0 top-0 h-full w-full pointer-events-none" viewBox="0 0 120 600" fill="none">
            <path id="travel-path" d="M60,10 C20,120 100,240 60,350 C20,460 100,530 60,590" stroke="#D6CFC4" stroke-width="1.5" stroke-dasharray="4 6" />
            <!-- Nœuds de transition -->
            <circle cx="60" cy="10" r="4" fill="#C8813A" />
            <circle cx="38" cy="120" r="3" fill="#C8813A" class="opacity-60" />
            <circle cx="82" cy="240" r="3" fill="#C8813A" class="opacity-60" />
            <circle cx="60" cy="350" r="4" fill="#C8813A" />
            <circle cx="60" cy="590" r="4" fill="#C8813A" />
          </svg>

          <!-- Le Van de Voyage Dessiné en SVG Minimaliste -->
          <div id="scrolling-van" class="absolute w-12 h-12 flex items-center justify-center transition-transform duration-100 ease-out" style="left: calc(50% - 24px); top: 0px;">
            <svg viewBox="0 0 24 24" fill="none" class="w-full h-full">
              <!-- Galerie de toit (Ambre #C8813A) -->
              <path d="M6 5.5h12M8 4.5h8" stroke="#C8813A" stroke-width="1" stroke-linecap="round"/>
              <!-- Carrosserie (Ardoise #2C3E50) -->
              <rect x="4" y="6" width="16" height="11" rx="3" fill="#2C3E50" stroke="#2C3E50" stroke-width="1" />
              <!-- Pare-brise et fenêtres (Alabaster #F5F2ED semi-trans) -->
              <rect x="6" y="8" width="5" height="3" rx="1" fill="#F5F2ED" fill-opacity="0.7" />
              <rect x="13" y="8" width="5" height="3" rx="1" fill="#F5F2ED" fill-opacity="0.7" />
              <!-- Phares (Ambre #C8813A) -->
              <circle cx="6" cy="14" r="1" fill="#C8813A" />
              <circle cx="18" cy="14" r="1" fill="#C8813A" />
              <!-- Pare-chocs (Gris #E0D9D0) -->
              <rect x="3" y="16.5" width="18" height="1" rx="0.5" fill="#E0D9D0" />
              <!-- Roues -->
              <circle cx="7" cy="18" r="2" fill="#171717" />
              <circle cx="17" cy="18" r="2" fill="#171717" />
            </svg>
          </div>

          <div class="absolute bottom-4 text-center font-mono text-[8px] uppercase tracking-[0.3em] text-[#5a5248]">
            En route...
          </div>
        </div>
      </aside>

    </div>
  </div>

  <!-- BOUTON RETOUR EN PIED DE PAGE -->
  <div class="w-full bg-[#FAF9F6] py-16 border-t border-[#E0D9D0] relative z-20">
    <div class="max-w-[1600px] mx-auto px-8 sm:px-12 text-center">
      <a href="/#destinations" class="inline-block text-[10px] font-mono uppercase tracking-[0.25em] bg-neutral-900 text-white font-bold px-8 py-4 rounded-xl hover:bg-amber-600 hover:scale-102 transition-all duration-300 shadow-xs">
        ← Retourner au Tabloir d'Exploration
      </a>
    </div>
  </div>
</Layout>

<script>
  // Initialisation et gestion dynamique du scroll-van et des favoris
  document.addEventListener('DOMContentLoaded', () => {
    const van = document.getElementById('scrolling-van');
    const path = document.getElementById('travel-path') as SVGPathElement | null;
    const destFavBtn = document.getElementById('dest-fav-btn');

    // 1. ANIMATION DU VAN SVG AU SCROLL (Progression géométrique le long de la courbe) [4]
    if (van && path) {
      const pathLength = path.getTotalLength();
      
      const animateVan = () => {
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercent = Math.min(Math.max(window.scrollY / (docHeight || 1), 0), 1);
        
        // Calcul du point x et y précis sur la courbe de Bézier du tracé pointillé
        const point = path.getPointAtLength(scrollPercent * pathLength);
        
        // Repositionne le van selon les coordonnées du SVG [4]
        van.style.transform = `translate(${point.x - 50}px, ${point.y - 120}px)`;
      };

      window.addEventListener('scroll', animateVan, { passive: true });
      animateVan(); // Premier calcul
    }

    // 2. SYNCHRONISATION DU BOUTON FAVORIS LOCAL DE LA CARD
    if (destFavBtn) {
      const cardId = destFavBtn.getAttribute('data-id');

      const getFavorites = (): string[] => {
        try {
          const stored = localStorage.getItem('the_odyssey_favorites');
          return stored ? JSON.parse(stored) : [];
        } catch (e) { return []; }
      };

      const isFavorite = (id: string) => getFavorites().includes(id);

      const updateFavButtonUI = () => {
        if (!cardId) return;
        const svg = destFavBtn.querySelector('svg');
        if (svg) {
          if (isFavorite(cardId)) {
            svg.classList.add('text-amber-500', 'fill-amber-500', 'stroke-white');
            svg.classList.remove('text-white/90');
          } else {
            svg.classList.remove('text-amber-500', 'fill-amber-500', 'stroke-white');
            svg.classList.add('text-white/90');
          }
        }
      };

      destFavBtn.addEventListener('click', () => {
        if (!cardId) return;
        let favs = getFavorites();
        if (favs.includes(cardId)) {
          favs = favs.filter(id => id !== cardId);
        } else {
          favs.push(cardId);
        }
        localStorage.setItem('the_odyssey_favorites', JSON.stringify(favs));
        updateFavButtonUI();
      });

      updateFavButtonUI();
    }
  });
</script>
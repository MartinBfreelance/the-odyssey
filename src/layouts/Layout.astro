---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth bg-[#FAF9F6]">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<!-- Correction des URLs Google Fonts Preconnect -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#FAF9F6] text-neutral-900 antialiased min-h-screen flex flex-col justify-between">
		
		<!-- EN-TÊTE GLASSMORPHISM : FIXE AU DÉPART, RESTE EN HAUT ET APPLIQUE LE FLOU BLUR SANS FOND BLANC OPAQUE (STYLE BOKO STUDIO) -->
		<header class="w-full fixed top-0 left-0 z-50 bg-neutral-950/10 backdrop-blur-md border-b border-white/10 transition-all duration-300">
			<div class="max-w-7xl mx-auto px-8 h-20 flex items-center justify-between">
				
				<!-- BLOC MARQUE GAUCHE COMPOSÉ EN BLANC PUR -->
				<a href="#" class="flex items-center space-x-4 group">
					<!-- Boussole fine blanche qui pivote au survol -->
					<div class="w-8 h-8 text-white group-hover:text-amber-400 relative flex items-center justify-center">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-full h-full">
							<circle cx="12" cy="12" r="10" />
							<circle cx="12" cy="12" r="7" stroke-dasharray="2 2" />
							<path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.5" />
						</svg>
						<div class="absolute inset-0 flex items-center justify-center group-hover:rotate-180 transition-transform duration-1000 ease-out">
							<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-full h-full scale-60 text-white group-hover:text-amber-400">
								<path d="M12 2l2.5 7.5L12 12l-2.5-2.5L12 2zm0 20l2.5-7.5L12 12l-2.5 2.5L12 22z" />
							</svg>
						</div>
					</div>
					<div class="flex flex-col">
						<span class="text-sm font-serif tracking-[0.35em] font-bold text-white group-hover:text-amber-400 transition-colors">THE ODYSSEY</span>
						<span class="text-[7px] font-mono tracking-[0.2em] text-white/60 uppercase mt-0.5">Slow Travel Magazine</span>
					</div>
				</a>

				<!-- BLOC NAVIGATION DROITE -->
				<div class="flex items-center space-x-12">
					<nav class="hidden md:flex items-center space-x-10 text-[10px] font-mono uppercase tracking-[0.25em]">
						<a href="#destinations" class="relative py-2 text-white hover:text-amber-400 hover:scale-105 transition-all duration-300 group/link">
							Destinations
							<span class="absolute bottom-0 left-0 w-0 h-[1.5px] bg-amber-400 transition-all duration-300 group-hover/link:w-full"></span>
						</a>
						<a href="#bons-plans" class="relative py-2 text-white/90 hover:text-amber-400 hover:scale-105 transition-all duration-300 group/link">
							Bons Plans
							<span class="absolute bottom-0 left-0 w-0 h-[1.5px] bg-amber-400 transition-all duration-300 group-hover/link:w-full"></span>
						</a>
						<a href="#astuces" class="relative py-2 text-white/90 hover:text-amber-400 hover:scale-105 transition-all duration-300 group/link">
							Astuces
							<span class="absolute bottom-0 left-0 w-0 h-[1.5px] bg-amber-400 transition-all duration-300 group-hover/link:w-full"></span>
						</a>
					</nav>
					
					<!-- Bouton Privilèges blanc contrasté style Boko Studio -->
					<a href="#bons-plans" class="text-[10px] font-mono uppercase tracking-[0.2em] bg-white text-neutral-950 px-5 py-2.5 hover:bg-amber-500 hover:text-white hover:scale-102 transition-all duration-300 rounded-xs shadow-xs">
						Privilèges 🎁
					</a>
				</div>

			</div>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<!-- FOOTER MAGAZINE -->
		<footer class="bg-neutral-950 text-neutral-500 py-16 px-8 text-xs font-mono text-[9px] tracking-widest border-t border-neutral-900">
			<div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-6">
				<p class="text-white font-serif uppercase tracking-[0.3em] text-xs">THE ODYSSEY</p>
				<p class="text-neutral-600">&copy; {new Date().getFullYear()} THE ODYSSEY MAGAZINE. TOUS DROITS RÉSERVÉS.</p>
			</div>
		</footer>

	</body>
</html>

<style is:global>
	h1, h2, h3, .font-serif { font-family: 'Playfair Display', serif; }
	body, .font-sans { font-family: 'Inter', sans-serif; }

	/* Texture de papier fine, presque imperceptible (opacité de 1.2%) sur fond blanc albâtre */
	body {
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 250 250' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.012'/%3E%3C/svg%3E");
	}
</style>
---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth bg-[#FAF9F6]">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link rel="preconnect" href="https://googleapis.com">
		<link rel="preconnect" href="https://gstatic.com" crossorigin>
		<link href="https://googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#FAF9F6] text-neutral-900 antialiased min-h-screen flex flex-col justify-between">
		
		<!-- HEADER UNIQUE ET SÉCURISÉ STYLE LUXE (COMME BOKO STUDIO) -->
		<header class="w-full border-b border-neutral-200/60 bg-white/80 backdrop-blur-md sticky top-0 z-50">
			<div class="max-w-7xl mx-auto px-8 h-20 flex items-center justify-between">
				<a href="#" class="flex flex-col group">
					<span class="text-sm font-serif tracking-[0.4em] font-bold text-neutral-900 group-hover:text-amber-700 transition-colors">THE ODYSSEY</span>
					<span class="text-[7px] font-mono tracking-[0.2em] text-neutral-400 uppercase mt-1">Slow Travel Magazine</span>
				</a>
				<nav class="hidden md:flex items-center space-x-12 text-[10px] font-mono uppercase tracking-[0.2em] text-neutral-500">
					<a href="#destinations" class="text-neutral-900 hover:text-amber-700 transition-colors">Destinations</a>
					<a href="#bons-plans" class="hover:text-amber-700 transition-colors">Bons Plans</a>
					<a href="#astuces" class="hover:text-amber-700 transition-colors">Astuces</a>
				</nav>
				<a href="#bons-plans" class="text-[10px] font-mono uppercase tracking-[0.2em] bg-neutral-950 text-white px-5 py-2.5 hover:bg-amber-700 transition-colors">
					Privilèges 🎁
				</a>
			</div>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<!-- FOOTER MAGAZINE -->
		<footer class="bg-neutral-950 text-neutral-500 py-16 px-8 text-xs font-mono text-[9px] tracking-widest border-t border-neutral-900">
			<div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-6">
				<p class="text-white font-serif uppercase tracking-[0.3em] text-xs">THE ODYSSEY</p>
				<p class="text-neutral-600">&copy; {new Date().getFullYear()} THE ODYSSEY MAGAZINE. TOUS DROITS RÉSERVÉS.</p>
			</div>
		</footer>

	</body>
</html>

<style is:global>
	h1, h2, h3, .font-serif { font-family: 'Playfair Display', serif; }
	body, .font-sans { font-family: 'Inter', sans-serif; }
</style>

---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
import destinationsData from '../data/destinations.json';
import partners from '../data/partners.json';

// Lecture de l'URL courante pour adapter dynamiquement les ancres de navigation
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html' || pathname === '';
const destinationsHref = isHome ? "#destinations" : "/#destinations";

const bonsPlansHref = "/bons-plans";

// Tri et classification automatique des destinations par continent
const continents = ["Europe", "Amérique", "Asie"];
const groupedDestinations = continents.reduce((acc, continent) => {
  acc[continent] = destinationsData.filter(dest => dest.continent === continent);
  return acc;
}, {} as Record<string, typeof destinationsData>);
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth bg-[#FAF9F6]">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<!-- Masquer la technologie sous-jacente aux robots d'exploration -->
		<meta name="generator" content="" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<!-- Preconnect Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Playfair+Display:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#FAF9F6] text-neutral-900 antialiased min-h-screen flex flex-col justify-between">
		
		<!-- EN-TÊTE GLASSMORPHISM -->
		<header class="w-full fixed top-0 left-0 z-50 bg-neutral-950/10 backdrop-blur-md border-b border-white/10 transition-all duration-300">
			<div class="max-w-7xl mx-auto px-8 h-20 flex items-center justify-between">
				
				<!-- LOGO : BOUSSOLE ANIMÉE -->
				<a href="/" class="flex items-center space-x-3 group select-none">
					<div class="w-7 h-7 text-white group-hover:rotate-45 group-hover:text-amber-500 transition-all duration-500 ease-out shrink-0">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
							<circle cx="12" cy="12" r="10"></circle>
							<circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
							<path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2"></path>
							<path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
							<path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
						</svg>
					</div>

					<div class="flex flex-col text-left leading-none relative">
						<span class="relative font-serif text-sm sm:text-base font-medium tracking-[0.25em] text-white uppercase transition-colors duration-300 group-hover:text-amber-400">
							THE ODYSSEY
							<span class="absolute bottom-1 left-0 w-0 h-[6px] bg-amber-500/20 group-hover:w-full transition-all duration-500 ease-out -z-10 rounded-xs"></span>
						</span>
						<span class="text-[7.5px] font-mono tracking-[0.18em] uppercase text-neutral-400 mt-1 transition-all duration-300 group-hover:text-amber-200 group-hover:tracking-[0.22em]">
							Slow Travel Journal
						</span>
					</div>
				</a>

				<!-- BLOC NAVIGATION DROITE -->
				<div class="flex items-center">
					<nav class="hidden md:flex items-center space-x-10 text-[10px] font-mono uppercase tracking-[0.25em]">
						
						<!-- Menu Déroulant Destinations (Nomenclature par Continent) -->
						<div class="relative group/dropdown py-2">
							<a href={destinationsHref} class="relative py-2 text-white hover:text-amber-400 hover:scale-105 transition-all duration-300 group/link flex items-center gap-1.5 cursor-pointer">
								Destinations
								<span class="text-[7px] text-neutral-400 group-hover/dropdown:rotate-180 transition-transform duration-300">▼</span>
								<span class="absolute bottom-1 left-0 w-0 h-[3px] bg-amber-500/30 transition-all duration-300 group-hover/link:w-full -z-10 rounded-xs"></span>
							</a>
							<!-- Boîte de sous-menu classée par continent -->
							<div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 w-60 opacity-0 pointer-events-none group-hover/dropdown:opacity-100 group-hover/dropdown:pointer-events-auto transition-all duration-300 z-50">
								<div class="bg-neutral-950/95 backdrop-blur-md border border-white/10 rounded-xl py-3 px-2 shadow-xl space-y-3 max-h-[420px] overflow-y-auto">
									{continents.map((continent) => {
										const dests = groupedDestinations[continent];
										if (!dests || dests.length === 0) return null;
										return (
											<div class="space-y-1">
												<!-- En-tête de continent délicat ambré -->
												<div class="px-3 py-1 text-[7.5px] font-mono tracking-[0.3em] uppercase text-amber-500/80 font-bold border-b border-white/5 select-none">
													{continent}
												</div>
												<!-- Liste des pays de ce continent -->
												<div class="space-y-0.5">
													{dests.map((dest) => (
														<a href={`/destinations/${dest.slug}`} class="block px-3 py-1.5 text-[9px] font-mono uppercase tracking-widest text-neutral-300 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200">
															{dest.titre.split(':')[0].trim()}
														</a>
													))}
												</div>
											</div>
										);
									})}
								</div>
							</div>
						</div>

						<!-- Menu Déroulant Bons Plans Génériques (100% Automatique via partners.json) -->
						<div class="relative group/dropdown py-2">
							<a href={bonsPlansHref} class="relative py-2 text-white hover:text-amber-400 hover:scale-105 transition-all duration-300 group/link flex items-center gap-1.5 cursor-pointer">
								Bons Plans
								<span class="text-[7px] text-neutral-400 group-hover/dropdown:rotate-180 transition-transform duration-300">▼</span>
								<span class="absolute bottom-1 left-0 w-0 h-[3px] bg-amber-500/30 transition-all duration-300 group-hover/link:w-full -z-10 rounded-xs"></span>
							</a>
							<div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 w-56 opacity-0 pointer-events-none group-hover/dropdown:opacity-100 group-hover/dropdown:pointer-events-auto transition-all duration-300 z-50">
								<div class="bg-neutral-950/95 backdrop-blur-md border border-white/10 rounded-xl py-2 px-1 shadow-xl">
									{partners.filter(p => p.active).map((p) => (
										<a href={`/bons-plans#${p.id}`} class="block px-4 py-2 text-[9px] font-mono uppercase tracking-widest text-neutral-300 hover:text-amber-400 hover:bg-white/5 rounded-lg transition-all duration-200 font-medium">
											{p.emoji} {p.category}
										</a>
									))}
								</div>
							</div>
						</div>
						
						<!-- Favoris -->
						<button id="favorites-menu-btn" class="relative group/fav-menu p-1 transition-colors duration-300 cursor-pointer shrink-0" aria-label="Voir les favoris">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" class="w-5.5 h-5.5 text-white transition-all duration-300 group-hover/fav-menu:scale-110 fav-menu-svg">
								<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
							</svg>
							<span id="favorites-dot" class="absolute -top-1 -right-1 w-2 h-2 rounded-full bg-amber-500 border border-neutral-900 scale-0 opacity-0 transition-all duration-300 ease-out"></span>
						</button>
					</nav>
				</div>

			</div>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<!-- PIED DE PAGE MAGAZINE -->
		<footer class="bg-neutral-950 text-neutral-400 py-16 px-6 sm:px-8 md:px-12 border-t border-neutral-900 font-mono text-[10px] tracking-widest relative z-20">
			<div class="max-w-[1600px] mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8 pb-16 border-b border-neutral-900">
				
				<!-- Signature -->
				<div class="md:col-span-5 space-y-6">
					<div class="flex items-center space-x-3 group/footer-logo cursor-pointer">
						<div class="w-8 h-8 text-neutral-500 group-hover/footer-logo:rotate-45 group-hover/footer-logo:text-amber-500 transition-all duration-500 ease-out shrink-0">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.8" stroke="currentColor" class="w-full h-full">
								<circle cx="12" cy="12" r="10"></circle>
								<circle cx="12" cy="12" r="7.2" stroke-dasharray="1.8 1.5"></circle>
								<path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke-width="1.2"></path>
								<path fill="currentColor" d="M12 4.5l2.2 7.5L12 14.2l-2.2-2.2z" class="text-amber-600"></path>
								<path fill="currentColor" d="M12 19.5l2.2-7.5L12 14.2l-2.2-2.2z" class="text-neutral-300"></path>
							</svg>
						</div>
						<div class="flex flex-col text-left leading-none relative">
							<span class="font-serif text-sm sm:text-base font-medium tracking-[0.25em] text-white uppercase transition-colors group-hover/footer-logo:text-amber-400">THE ODYSSEY</span>
							<span class="text-[7.5px] tracking-[0.18em] uppercase text-neutral-500 mt-1">Slow Travel Journal</span>
						</div>
					</div>
					<p class="text-neutral-500 font-light leading-relaxed max-w-sm tracking-normal text-[11px] font-sans">
						Un espace dédié à l'exploration lente, à la photographie sincère et aux récits vécus pas à pas.
					</p>
					
					<div class="flex items-center space-x-4 pt-2">
						<a href="https://instagram.com/the_odyssey_travel_journal" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-white transition-colors flex items-center space-x-2 group/footer-insta">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-neutral-400 group-hover/footer-insta:text-amber-500 transition-colors">
								<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
								<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
								<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
							</svg>
							<span>Instagram</span>
						</a>
						<span class="text-neutral-800">|</span>
						<a href="mailto:contact@the-odyssey.com" class="text-neutral-400 hover:text-white transition-colors flex items-center space-x-1.5">
							<span>✉️ Nous écrire</span>
						</a>
					</div>
				</div>

				<!-- Index Continent -->
				<div class="md:col-span-3 space-y-4">
					<p class="text-white font-bold uppercase tracking-widest text-[11px]">Explorations</p>
					<ul class="space-y-2.5 text-neutral-500 font-sans text-xs">
						<li><a href={isHome ? "#destinations" : "/#destinations"} data-continent-trigger="europe" class="hover:text-amber-500 transition-colors">Europe</a></li>
						<li><a href={isHome ? "#destinations" : "/#destinations"} data-continent-trigger="amerique" class="hover:text-amber-500 transition-colors">Amérique</a></li>
						<li><a href={isHome ? "#destinations" : "/#destinations"} data-continent-trigger="asie" class="hover:text-amber-500 transition-colors">Asie</a></li>
					</ul>
				</div>

				<!-- Liens partenaires génériques via partners.json -->
				<div class="md:col-span-4 space-y-4">
					<p class="text-white font-bold uppercase tracking-widest text-[11px]">Bons Plans Voyageurs</p>
					<ul class="space-y-2.5 text-neutral-500 font-sans text-xs">
						{partners.filter(p => p.active).map((p) => (
							<li>
								<a href={`/bons-plans#${p.id}`} class="hover:text-amber-500 transition-colors">
									{p.emoji} {p.category}
								</a>
							</li>
						))}
					</ul>
				</div>

			</div>

			<div class="max-w-[1600px] mx-auto pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-neutral-600">
				<p class="text-center md:text-left text-[9px] uppercase tracking-[0.18em]">
					&copy; {new Date().getFullYear()} THE ODYSSEY SLOW TRAVEL JOURNAL. TOUS DROITS RÉSERVÉS.
				</p>
				<div class="flex space-x-6 text-[9px] uppercase tracking-[0.18em]">
					<a href="#" class="hover:text-neutral-400 transition-colors">Mentions Légales</a>
					<span>•</span>
					<a href="#" class="hover:text-neutral-400 transition-colors">Confidentialité</a>
				</div>
			</div>
		</footer>

		<!-- Script global -->
		<script>
			function getGlobalFavorites(): string[] {
				try {
					const stored = localStorage.getItem('the_odyssey_favorites');
					return stored ? JSON.parse(stored) : [];
				} catch (e) { return []; }
			}

			function syncGlobalMenuFavorites() {
				const favs = getGlobalFavorites();
				const menuBtn = document.getElementById('favorites-menu-btn');
				const menuSvg = menuBtn ? menuBtn.querySelector('.fav-menu-svg') as SVGElement | null : null;
				const dot = document.getElementById('favorites-dot') as HTMLElement | null;

				if (menuSvg) {
					if (favs.length > 0) {
						menuSvg.classList.add('text-amber-500', 'fill-amber-500', 'stroke-white');
						menuSvg.classList.remove('text-white');
						menuSvg.setAttribute('stroke-width', '2.5');
					} else {
						menuSvg.classList.remove('text-amber-500', 'fill-amber-500', 'stroke-white');
						menuSvg.classList.add('text-white');
						menuSvg.setAttribute('stroke-width', '1.8');
					}
				}

				if (dot) {
					if (favs.length > 0) {
						dot.classList.add('scale-100', 'opacity-100');
						dot.classList.remove('scale-0', 'opacity-0');
					} else {
						dot.classList.add('scale-0', 'opacity-0');
						dot.classList.remove('scale-100', 'opacity-100');
					}
				}
			}

			(window as any).syncGlobalMenuFavorites = syncGlobalMenuFavorites;

			document.addEventListener('DOMContentLoaded', () => {
				const pathname = window.location.pathname;
				const isHome = pathname === '/' || pathname === '/index.html' || pathname === '';
				
				syncGlobalMenuFavorites();

				const menuBtn = document.getElementById('favorites-menu-btn');
				if (menuBtn) {
					menuBtn.addEventListener('click', (e) => {
						if (!isHome) {
							e.preventDefault();
							try {
								sessionStorage.setItem('odyssey_home_filter', 'favorites');
								sessionStorage.removeItem('odyssey_home_scroll');
							} catch (err) {}
							window.location.href = '/#destinations';
						}
					});
				}

				if (!isHome) {
					const navLinks = document.querySelectorAll('header nav a');
					navLinks.forEach(link => {
						link.addEventListener('click', () => {
							try {
								sessionStorage.removeItem('odyssey_home_scroll');
								sessionStorage.removeItem('odyssey_home_filter');
							} catch (err) {}
						});
					});

					const logoLink = document.querySelector('header a[href="/"]');
					if (logoLink) {
						logoLink.addEventListener('click', () => {
							try {
								sessionStorage.removeItem('odyssey_home_scroll');
								sessionStorage.removeItem('odyssey_home_filter');
							} catch (err) {}
						});
					}

					const footerContinentLinks = document.querySelectorAll('[data-continent-trigger]') as NodeListOf<HTMLElement>;
					footerContinentLinks.forEach(link => {
						link.addEventListener('click', () => {
							const continentValue = link.getAttribute('data-continent-trigger');
							if (continentValue) {
								try {
									sessionStorage.setItem('odyssey_home_filter', continentValue);
									sessionStorage.removeItem('odyssey_home_scroll');
								} catch (err) {}
							}
						});
					});
				}
			});

			window.addEventListener('storage', (e) => {
				if (e.key === 'the_odyssey_favorites') {
					syncGlobalMenuFavorites();
				}
			});
		</script>
	</body>
</html>

<style is:global>
	h1, h2, h3, .font-serif { font-family: 'Playfair Display', serif; }
	body, .font-sans { font-family: 'Inter', sans-serif; }

	body {
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 250 250' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.012'/%3E%3C/svg%3E");
	}
</style>